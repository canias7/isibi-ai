{
  "name": "isibi-app",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-mac": "electron-builder --mac --dir",
    "build-win": "electron-builder --win --dir"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "ai.isibi.app",
    "productName": "APP_NAME_PLACEHOLDER",
    "mac": {
      "category": "public.app-category.business",
      "target": ["dmg", "zip"],
      "icon": "icon.png"
    },
    "win": {
      "target": ["nsis"],
      "icon": "icon.png"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "icon.png"
    },
    "directories": {
      "output": "dist"
    }
  }
}
