# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/crm

# Redis (optional — falls back to in-memory if not set)
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=72

# Email (Resend)
RESEND_API_KEY=

# Cloudflare Turnstile (leave empty to skip in dev)
TURNSTILE_SECRET_KEY=

# Anthropic AI
ANTHROPIC_API_KEY=

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# App settings
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
UPLOADS_DIR=./uploads
PROJECTS_DIR=./generated

# Testing (set to 1 to disable rate limiting)
TESTING=
