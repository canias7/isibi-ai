{
  "name": "go-farther",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Go Farther — one chat for all your apps.",
  "author": "Go Farther",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "eslint . && tsc && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "evals": "node evals/run.mjs",
    "electron:dev": "ELECTRON_START_URL=http://localhost:5173 electron electron/main.cjs",
    "electron:preview": "ELECTRON=1 vite build && electron electron/main.cjs",
    "electron:build": "ELECTRON=1 vite build && electron-builder",
    "electron:build:mac": "ELECTRON=1 vite build && electron-builder --mac --arm64",
    "electron:build:win": "ELECTRON=1 vite build && electron-builder --win",
    "electron:build:linux": "ELECTRON=1 vite build && electron-builder --linux"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/geolocation": "^8.0.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/push-notifications": "^8.1.1",
    "@capgo/capacitor-updater": "^8.47.6",
    "@supabase/supabase-js": "^2.107.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
