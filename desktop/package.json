{
  "name": "isibi-control-center",
  "productName": "ISIBI Control Center",
  "version": "3.0.0",
  "description": "Desktop control center for managing your isibi.ai apps",
  "author": "isibi.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/canias7/isibi-ai.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --win --linux",
    "build-mac": "electron-builder --mac",
    "build-win": "electron-builder --win",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "ai.isibi.control-center",
    "publish": [
      {
        "provider": "github",
        "owner": "canias7",
        "repo": "isibi-ai"
      }
    ],
    "productName": "ISIBI Control Center",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "renderer.js",
      "app-config.json",
      "icon.png"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "icon.png",
      "target": [
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ],
      "artifactName": "ISIBI-Control-Center-macOS.${ext}"
    },
    "win": {
      "icon": "icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "ISIBI-Control-Center-Setup.${ext}"
    },
    "linux": {
      "icon": "icon.png",
      "category": "Development",
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "artifactName": "ISIBI-Control-Center.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "dmg": {
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  },
  "dependencies": {
    "electron-updater": "^6.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
