        "list_view": {
          "layout": "table",
          "columns": [
            "company_name",
            "contact_name",
            "email",
            "platforms",
            "monthly_retainer",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Clients yet",
            "subtext": "Create your first client",
            "action_label": "Add Client"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "active",
                "paused",
                "churned",
                "prospect"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "company_name",
            "contact_name",
            "email"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "company_name",
            "contact_name",
            "email",
            "platforms",
            "monthly_retainer",
            "status"
          ],
          "required_fields": [
            "company_name",
            "contact_name"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "company_name",
            "contact_name",
            "email",
            "platforms",
            "monthly_retainer",
            "status"
          ],
          "required_fields": [
            "company_name",
            "contact_name"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/clients/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "company_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "company_name",
            "contact_name",
            "email",
            "platforms"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "company_name",
                "contact_name",
                "email",
                "platforms",
                "monthly_retainer",
                "status"
              ]
            }
          ]
        }
      }
