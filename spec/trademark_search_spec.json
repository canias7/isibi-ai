          "primary_fields": [
            "client",
            "mark",
            "class",
            "type"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "client",
                "mark",
                "class",
                "type",
                "status"
              ]
            }
          ]
        }
      }
