  "dashboard": {
    "stat_cards": [
      {
        "label": "Total Campaigns",
        "entity": "Campaign",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Campaigns",
        "entity": "Campaign",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "active"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Completed Campaigns",
        "entity": "Campaign",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "completed"
        },
        "icon": "CheckCircle",
        "color": "emerald"
