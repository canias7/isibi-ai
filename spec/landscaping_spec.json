{
  "_meta": {
    "app_name": "Landscaping",
    "description": "Landscaping service"
  },
  "entities": [
    {
      "name": "Job",
      "table": "jobs",
      "description": "Landscaping job",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "client_id",
          "db_type": "UUID",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "relation_picker",
          "display_component": "relation_link",
          "foreign_key": {
            "table": "clients",
            "column": "id",
            "display_column": "name"
          }
        },
        {
          "name": "client_name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "address",
          "db_type": "VARCHAR(500)",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Street, City, State, ZIP",
          "help_text": "Full mailing address"
        },
        {
          "name": "type",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "mowing",
            "planting",
            "hardscape",
            "irrigation",
            "cleanup",
            "design"
          ],
          "badge_colors": {
            "mowing": "green",
            "planting": "green",
            "hardscape": "amber",
            "irrigation": "blue",
            "cleanup": "slate",
            "design": "purple"
          }
        },
        {
          "name": "crew_lead",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "price",
          "db_type": "NUMERIC(10,2)",
          "ts_type": "number",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text",
          "validation": {
            "min": 0,
            "message": "Price must be a positive number"
          },
          "placeholder": "0.00",
          "help_text": "Price in USD"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "scheduled",
            "in_progress",
            "completed",
            "cancelled"
          ],
          "badge_colors": {
            "scheduled": "blue",
            "in_progress": "amber",
            "completed": "green",
            "cancelled": "red"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "client_name",
            "address",
            "type",
            "crew_lead",
            "price",
            "status",
            "client_id"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Jobs yet",
            "subtext": "Create your first job",
            "action_label": "Add Job"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "scheduled",
                "in_progress",
                "completed",
                "cancelled"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "client_name",
            "address",
            "crew_lead"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Completed",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "completed"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client_name",
            "address",
            "type",
            "crew_lead",
            "price",
            "status",
            "client_id"
          ],
          "required_fields": [
            "client_name",
            "address"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client_name",
            "address",
            "type",
            "crew_lead",
            "price",
            "status",
            "client_id"
          ],
          "required_fields": [
            "client_name",
            "address"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/jobs/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "client_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "client_name",
            "address",
            "type",
            "crew_lead"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "client_name",
                "address",
                "type",
                "crew_lead",
                "price",
                "status",
                "client_id"
              ]
            }
          ]
        }
      }
    },
