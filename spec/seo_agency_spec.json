        "list_view": {
          "layout": "table",
          "columns": [
            "company",
            "website",
            "monthly_retainer",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Clients yet",
            "subtext": "Add client",
            "action_label": "Add Client"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "company",
            "website",
            "monthly_retainer",
            "status"
          ],
          "required_fields": [
            "company",
            "website"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "company",
            "website",
            "monthly_retainer",
            "status"
          ],
          "required_fields": [
            "company",
            "website"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/clients/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "company"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "company",
            "website",
            "monthly_retainer",
            "status"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "company",
                "website",
                "monthly_retainer",
                "status"
              ]
            }
          ]
        }
      }
    },
