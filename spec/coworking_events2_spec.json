            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "product_type",
            "email",
            "phone"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "product_type",
                "email",
                "phone",
                "status"
