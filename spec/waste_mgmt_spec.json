  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Pickup",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Pickups",
        "entity": "Pickup",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "active"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Total Routes",
        "entity": "Route",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Active Routes",
        "entity": "Route",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "active"
        },
        "icon": "Activity",
        "color": "green"
      }
    ]
