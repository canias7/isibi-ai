      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "customer",
            "address",
            "type",
            "frequency",
            "day",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Pickups yet",
            "subtext": "Add pickup",
            "action_label": "Add Pickup"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "active",
                "suspended",
                "cancelled"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "customer",
            "address",
            "day"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Cancelled",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "cancelled"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer",
            "address",
            "type",
            "frequency",
            "day",
            "status"
          ],
          "required_fields": [
            "customer",
            "address"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer",
            "address",
            "type",
            "frequency",
            "day",
            "status"
          ],
          "required_fields": [
            "customer",
            "address"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/pickups/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "customer"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "customer",
            "address",
            "type",
            "frequency"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "customer",
                "address",
                "type",
                "frequency",
                "day",
                "status"
              ]
            }
          ]
        }
      }
    },
