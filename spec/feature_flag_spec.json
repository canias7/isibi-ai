      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "key",
            "name",
            "type",
            "enabled",
            "environment"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Flags yet",
            "subtext": "Add flag",
            "action_label": "Add Flag"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "key",
            "name",
            "description",
            "type",
            "enabled",
            "environment"
          ],
          "required_fields": [
            "key",
            "name"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "key",
            "name",
            "description",
            "type",
            "enabled",
            "environment"
          ],
          "required_fields": [
            "key",
            "name"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/flags/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "key"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "key",
            "name",
            "type",
            "enabled"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "key",
                "name",
                "type",
                "enabled",
                "environment"
              ]
            }
          ]
        }
      }
    },
