          "badge_colors": {
            "received": "pink",
            "processing": "blue",
            "analyzed": "green",
            "reported": "amber"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "patient_name",
            "type",
            "collected_date",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Samples yet",
            "subtext": "Add sample",
            "action_label": "Add Sample"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "patient_name",
            "type",
            "collected_date",
            "status"
          ],
          "required_fields": [
            "patient_name",
            "type"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "patient_name",
            "type",
            "collected_date",
            "status"
          ],
          "required_fields": [
            "patient_name",
            "type"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/samples/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "patient_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "patient_name",
            "type",
            "collected_date",
            "status"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "patient_name",
                "type",
                "collected_date",
                "status"
              ]
            }
          ]
        }
      }
    },
