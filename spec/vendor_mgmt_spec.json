            "active",
            "probation",
            "inactive"
          ],
          "badge_colors": {
            "active": "pink",
            "probation": "blue",
            "inactive": "green"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "category",
            "contact",
            "rating",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Vendors",
            "subtext": "Add Vendor",
            "action_label": "Add Vendor"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "category",
            "contact",
            "rating",
            "status"
          ],
          "required_fields": [
            "name",
            "category"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "category",
            "contact",
            "rating",
            "status"
          ],
          "required_fields": [
            "name",
            "category"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/vendors/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "category",
            "contact",
            "rating"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "category",
                "contact",
                "rating",
                "status"
              ]
            }
          ]
        }
      }
    },
