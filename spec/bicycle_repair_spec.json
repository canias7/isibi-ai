            "customer",
            "bike_type",
            "issue",
            "price",
            "status"
          ],
          "required_fields": [
            "customer",
            "bike_type"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/jobs/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "customer"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "customer",
            "bike_type",
            "price",
            "status"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "customer",
                "bike_type",
                "price",
                "status"
              ]
            }
          ]
        }
      }
    },
