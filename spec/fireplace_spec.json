{
  "_meta": {
    "app_name": "Fireplace",
    "description": "Fireplace sales/service"
  },
  "entities": [
    {
      "name": "Job",
      "table": "jobs",
      "description": "Job",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "customer_name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "type",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "gas_install",
            "wood_install",
            "electric_install",
            "gas_log",
            "insert",
            "repair",
            "inspection",
            "chimney"
          ],
          "badge_colors": {
            "gas_install": "pink",
            "wood_install": "blue",
            "electric_install": "green",
            "gas_log": "amber",
            "insert": "purple",
            "repair": "red",
            "inspection": "slate",
            "chimney": "pink"
          }
        },
        {
          "name": "brand",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "price",
          "db_type": "NUMERIC(10,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text",
          "validation": {
            "min": 0,
            "message": "Price must be a positive number"
          },
          "placeholder": "0.00",
          "help_text": "Price in USD"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "estimate",
            "scheduled",
            "installing",
            "inspection",
            "completed"
          ],
          "badge_colors": {
            "estimate": "pink",
            "scheduled": "blue",
            "installing": "green",
            "inspection": "amber",
            "completed": "purple"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "customer_name",
            "type",
            "brand",
            "price",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Jobs yet",
            "subtext": "Add job",
            "action_label": "Add Job"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "estimate",
                "scheduled",
                "installing",
                "inspection",
                "completed"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "customer_name",
            "brand"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Completed",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "completed"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "type",
            "brand",
            "price",
            "status"
          ],
          "required_fields": [
            "customer_name",
            "type"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "type",
            "brand",
            "price",
            "status"
          ],
          "required_fields": [
            "customer_name",
            "type"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/jobs/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "customer_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "customer_name",
            "type",
            "brand",
            "price"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "customer_name",
                "type",
                "brand",
                "price",
                "status"
              ]
            }
          ]
        }
      }
    },
