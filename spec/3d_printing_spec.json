{
  "_meta": {
    "app_name": "3D Printing",
    "description": "3D Printing management"
  },
  "entities": [
    {
      "name": "Job",
      "table": "jobs",
      "description": "Job",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "customer",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Customer name",
          "help_text": "Customer full name"
        },
        {
          "name": "material",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "pla",
            "abs",
            "petg",
            "nylon",
            "resin",
            "metal",
            "tpu"
          ],
          "badge_colors": {
            "pla": "pink",
            "abs": "blue",
            "petg": "green",
            "nylon": "amber",
            "resin": "purple",
            "metal": "red",
            "tpu": "slate"
          }
        },
        {
          "name": "technology",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "fdm",
            "sla",
            "sls",
            "dmls",
            "polyjet"
          ],
          "badge_colors": {
            "fdm": "pink",
            "sla": "blue",
            "sls": "green",
            "dmls": "amber",
            "polyjet": "purple"
          }
        },
        {
          "name": "pieces",
          "db_type": "INTEGER",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text",
          "validation": {
            "min": 1,
            "message": "Must be at least 1"
          }
        },
        {
          "name": "price",
          "db_type": "NUMERIC(10,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text",
          "validation": {
            "min": 0,
            "message": "Price must be a positive number"
          },
          "placeholder": "0.00",
          "help_text": "Price in USD"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "file_review",
            "slicing",
            "printing",
            "post_processing",
            "done"
          ],
          "badge_colors": {
            "file_review": "pink",
            "slicing": "blue",
            "printing": "green",
            "post_processing": "amber",
            "done": "purple"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "customer",
            "material",
            "technology",
            "pieces",
            "price",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Jobs yet",
            "subtext": "Add job",
            "action_label": "Add Job"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "file_review",
                "slicing",
                "printing",
                "post_processing",
                "done"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "customer"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Done",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "done"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer",
            "material",
            "technology",
            "pieces",
            "price",
            "status"
          ],
          "required_fields": [
            "customer",
            "material"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer",
            "material",
            "technology",
            "pieces",
            "price",
            "status"
          ],
          "required_fields": [
            "customer",
            "material"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/jobs/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "customer"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "customer",
            "material",
            "technology",
            "pieces"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "customer",
                "material",
                "technology",
                "pieces",
                "price",
                "status"
              ]
            }
          ]
        }
      }
    },
