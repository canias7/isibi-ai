  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Test",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Tests",
        "entity": "Test",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "scheduled"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Total Capacity Tons",
        "entity": "Test",
        "method": "sum",
        "field": "capacity_tons",
        "icon": "DollarSign",
        "color": "amber"
      },
      {
        "label": "Total Equipments",
        "entity": "Equipment",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      }
    ]
