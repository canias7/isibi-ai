            "type",
            "model",
            "last_serviced",
            "status"
          ],
          "required_fields": [
            "location",
            "type"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/machines/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "location"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "location",
            "type",
            "model",
            "last_serviced"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "location",
                "type",
                "model",
                "last_serviced",
                "status"
              ]
            }
          ]
        }
