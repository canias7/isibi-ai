          "layout": "tabbed",
          "header": {
            "title_fields": [
              "client_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "client_name",
            "type",
            "deadline",
            "status"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "client_name",
                "type",
                "deadline",
                "status"
              ]
            }
          ]
        }
