          "type": "SlideOverForm",
          "field_order": [
            "name",
            "cuisine",
            "difficulty",
            "prep_min",
            "servings",
            "price"
          ],
          "required_fields": [
            "name",
            "cuisine"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "cuisine",
            "difficulty",
            "prep_min",
            "servings",
            "price"
          ],
          "required_fields": [
            "name",
            "cuisine"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/recipes/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "cuisine",
            "difficulty",
            "prep_min"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "cuisine",
                "difficulty",
                "prep_min",
                "servings",
                "price"
              ]
            }
          ]
        }
      }
    },
