  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Athlete",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Athletes",
        "entity": "Athlete",
        "method": "count",
