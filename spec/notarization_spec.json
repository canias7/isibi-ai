{
  "_meta": {
    "app_name": "Notarization",
    "description": "Notarization management"
  },
  "entities": [
    {
      "name": "Document",
      "table": "documents",
      "description": "Document",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "client",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "type",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "acknowledgment",
            "jurat",
            "oath",
            "copy_certification",
            "signature_witnessing"
          ],
          "badge_colors": {
            "acknowledgment": "pink",
            "jurat": "blue",
            "oath": "green",
            "copy_certification": "amber",
            "signature_witnessing": "purple"
          }
        },
        {
          "name": "documents_count",
          "db_type": "INTEGER",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "fee",
          "db_type": "NUMERIC(10,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "date",
          "db_type": "DATE",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "date_input",
          "display_component": "date"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "scheduled",
            "notarized",
            "recorded"
          ],
          "badge_colors": {
            "scheduled": "pink",
            "notarized": "blue",
            "recorded": "green"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "client",
            "type",
            "documents_count",
            "fee",
            "date",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Documents yet",
            "subtext": "Add document",
            "action_label": "Add Document"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client",
            "type",
            "documents_count",
            "fee",
            "date",
            "status"
          ],
          "required_fields": [
            "client",
            "type"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client",
            "type",
            "documents_count",
            "fee",
            "date",
            "status"
          ],
          "required_fields": [
            "client",
            "type"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/documents/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "client"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "client",
            "type",
            "documents_count",
            "fee"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "client",
                "type",
                "documents_count",
                "fee",
                "date",
                "status"
              ]
            }
          ]
        }
      }
    },
