  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Orders",
      "route": "/orders",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Order"
    },
    {
      "name": "Repairs",
      "route": "/repairs",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Repair"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Order",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Completed Orders",
        "entity": "Order",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "approved"
        },
        "icon": "CheckCircle",
        "color": "emerald"
      },
      {
        "label": "Total Price",
        "entity": "Order",
        "method": "sum",
        "field": "price",
        "icon": "DollarSign",
        "color": "amber"
      },
      {
        "label": "Total Repairs",
        "entity": "Repair",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      }
    ]
  },
  "design_system": {
    "theme": "light",
    "colors": {
      "primary": "#ec4899",
      "secondary": "#64748b",
      "background": "#ffffff",
      "surface": "#f8fafc",
      "text": "#0f172a",
      "muted": "#94a3b8"
    },
    "spacing": {
      "page_padding": "24px",
      "card_padding": "16px",
      "gap": "16px"
    },
    "buttons": {
      "primary": {
        "bg": "bg-pink-500",
        "text": "text-white",
        "hover": "hover:bg-pink-600"
      }
    },
    "table": {
