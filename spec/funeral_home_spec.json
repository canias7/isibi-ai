        {
          "name": "status",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "arrangement",
            "preparation",
            "scheduled",
            "completed"
          ],
          "badge_colors": {
            "arrangement": "blue",
            "preparation": "amber",
            "scheduled": "purple",
            "completed": "green"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "deceased_name",
            "family_contact",
            "contact_phone",
            "service_type",
            "date",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Cases yet",
            "subtext": "Create your first case",
            "action_label": "Add Case"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "deceased_name",
            "family_contact",
            "contact_phone",
            "service_type",
            "date",
            "status"
          ],
          "required_fields": [
            "deceased_name",
            "family_contact"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "deceased_name",
            "family_contact",
            "contact_phone",
            "service_type",
            "date",
            "status"
          ],
          "required_fields": [
            "deceased_name",
            "family_contact"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/cases/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "deceased_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "deceased_name",
            "family_contact",
            "contact_phone",
            "service_type"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "deceased_name",
                "family_contact",
                "contact_phone",
                "service_type",
                "date",
                "status"
              ]
            }
          ]
        }
      }
    },
