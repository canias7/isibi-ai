{
  "_meta": {
    "app_name": "Fleet Fuel",
    "description": "Fleet Fuel management"
  },
  "entities": [
    {
      "name": "Vehicle",
      "table": "vehicles",
      "description": "Vehicle",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "plate",
          "db_type": "VARCHAR(20) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "make",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "model",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "fuel_type",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "gasoline",
            "diesel",
            "electric",
            "hybrid",
            "cng"
          ],
          "badge_colors": {
            "gasoline": "pink",
            "diesel": "blue",
            "electric": "green",
            "hybrid": "amber",
            "cng": "purple"
          }
        },
        {
          "name": "odometer",
          "db_type": "INTEGER",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "plate",
            "make",
            "model",
            "fuel_type",
            "odometer"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Vehicles yet",
            "subtext": "Add vehicle",
            "action_label": "Add Vehicle"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "plate",
            "make",
            "model"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "plate",
            "make",
            "model",
            "fuel_type",
            "odometer"
          ],
          "required_fields": [
            "plate",
            "make"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "plate",
            "make",
            "model",
            "fuel_type",
            "odometer"
          ],
          "required_fields": [
            "plate",
            "make"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/vehicles/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "plate"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "plate",
            "make",
            "model",
            "fuel_type"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "plate",
                "make",
                "model",
                "fuel_type",
                "odometer"
              ]
            }
          ]
        }
      }
    },
    {
      "name": "FuelUp",
