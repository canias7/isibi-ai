              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Calendar",
              "layout": "calendar",
              "date_field": "date"
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
