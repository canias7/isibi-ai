          "type": "SlideOverForm",
          "field_order": [
            "name",
            "phone",
            "email",
            "license_type",
            "status"
          ],
          "required_fields": [
            "name",
            "phone"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "phone",
            "email",
            "license_type",
            "status"
          ],
          "required_fields": [
            "name",
            "phone"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/students/:id",
