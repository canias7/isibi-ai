          "primary_fields": [
            "project",
            "type",
            "sample_location",
            "result"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "project",
                "type",
                "sample_location",
                "result",
                "status"
              ]
            }
          ]
        }
      }
