          "type": "SlideOverForm",
          "field_order": [
            "name",
            "client",
            "metric",
            "target",
            "actual",
            "status"
          ],
          "required_fields": [
            "name",
            "client"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/slas/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "client",
            "metric",
            "target"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "client",
                "metric",
                "target",
                "actual",
                "status"
              ]
            }
          ]
        }
      }
    },
