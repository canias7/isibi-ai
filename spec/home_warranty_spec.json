      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "homeowner",
            "address",
            "plan",
            "annual_fee",
            "start_date",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Policys yet",
            "subtext": "Add policy",
            "action_label": "Add Policy"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            },
            {
              "name": "Calendar",
              "layout": "calendar",
              "date_field": "start_date"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "active",
                "expired",
                "cancelled"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "homeowner",
            "address"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Cancelled",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "cancelled"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "homeowner",
            "address",
            "plan",
            "annual_fee",
            "start_date",
            "status"
          ],
          "required_fields": [
            "homeowner",
            "address"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "homeowner",
            "address",
            "plan",
            "annual_fee",
            "start_date",
            "status"
          ],
          "required_fields": [
            "homeowner",
            "address"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/policies/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "homeowner"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "homeowner",
            "address",
            "plan",
            "annual_fee"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "homeowner",
                "address",
                "plan",
                "annual_fee",
                "start_date",
                "status"
              ]
            }
          ]
        }
      }
    },
