  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Policys",
      "route": "/policies",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Policy"
    },
    {
      "name": "Claims",
      "route": "/claims",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Claim"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Policy",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Policys",
        "entity": "Policy",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "active"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Total Annual Fee",
        "entity": "Policy",
        "method": "sum",
        "field": "annual_fee",
        "icon": "DollarSign",
        "color": "amber"
      },
      {
        "label": "Total Claims",
        "entity": "Claim",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      }
    ]
  },
