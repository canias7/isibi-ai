      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "category",
            "price",
            "daily_quantity"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Products yet",
            "subtext": "Create your first product",
            "action_label": "Add Product"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "category",
            "price",
            "daily_quantity"
          ],
          "required_fields": [
            "name",
            "category"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "category",
            "price",
            "daily_quantity"
          ],
          "required_fields": [
            "name",
            "category"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/products/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "category",
            "price",
            "daily_quantity"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "category",
                "price",
                "daily_quantity"
              ]
            }
          ]
        }
      }
