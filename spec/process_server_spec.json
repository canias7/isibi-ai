        "list_view": {
          "layout": "table",
          "columns": [
            "case_number",
            "attorney",
            "respondent",
            "address",
            "document_type",
            "attempts"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Services yet",
            "subtext": "Add service",
            "action_label": "Add Service"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "case_number",
            "attorney",
            "respondent",
            "address",
            "document_type",
            "attempts",
            "status"
          ],
          "required_fields": [
            "case_number",
            "attorney"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "case_number",
            "attorney",
            "respondent",
            "address",
            "document_type",
            "attempts",
            "status"
          ],
          "required_fields": [
            "case_number",
            "attorney"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/services/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "case_number"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "case_number",
            "attorney",
            "respondent",
            "address"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "case_number",
                "attorney",
                "respondent",
                "address",
                "document_type",
                "attempts"
              ]
            }
          ]
        }
      }
    },
