{
  "_meta": {
    "app_name": "Expense Tracker",
    "description": "Spreadsheet-style expense tracking and budget management"
  },
  "entities": [
    {
      "name": "Expense",
      "table": "expenses",
      "description": "Individual expense entry",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "date",
          "db_type": "DATE NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "date_picker",
          "display_component": "date",
          "placeholder": "Expense date",
          "help_text": "Date the expense occurred"
        },
        {
          "name": "description",
          "db_type": "VARCHAR(500) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "What was the expense for?",
          "help_text": "Brief description of the expense"
        },
        {
          "name": "category",
          "db_type": "VARCHAR(50) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "food",
            "transport",
            "utilities",
            "rent",
            "entertainment",
            "healthcare",
            "shopping",
            "travel",
            "education",
            "other"
          ],
          "badge_colors": {
            "food": "amber",
            "transport": "blue",
            "utilities": "green",
            "rent": "purple",
            "entertainment": "pink",
            "healthcare": "red",
            "shopping": "cyan",
            "travel": "indigo",
            "education": "teal",
            "other": "gray"
          }
        },
        {
          "name": "amount",
          "db_type": "NUMERIC(12,2) NOT NULL",
          "ts_type": "number",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "currency",
          "placeholder": "0.00",
          "help_text": "Expense amount"
        },
        {
          "name": "payment_method",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "cash",
            "credit_card",
            "debit_card",
            "bank_transfer",
            "check",
            "other"
          ],
          "badge_colors": {
            "cash": "green",
            "credit_card": "blue",
            "debit_card": "cyan",
            "bank_transfer": "purple",
            "check": "amber",
            "other": "gray"
          }
        },
        {
          "name": "vendor",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Store or vendor name",
          "help_text": "Where the purchase was made"
        },
        {
          "name": "receipt",
          "db_type": "VARCHAR(500)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": false,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Receipt URL or reference",
          "help_text": "Link to receipt image or reference number"
        },
        {
          "name": "notes",
          "db_type": "TEXT",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": false,
          "show_in_form": true,
          "input_component": "textarea",
          "display_component": "text",
          "placeholder": "Additional notes"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50) DEFAULT 'pending'",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "pending",
            "approved",
            "rejected",
            "reimbursed"
          ],
          "badge_colors": {
            "pending": "amber",
            "approved": "green",
            "rejected": "red",
            "reimbursed": "blue"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "date",
            "description",
            "category",
            "amount",
            "payment_method",
            "vendor",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Receipt",
            "heading": "No expenses yet",
            "subtext": "Start tracking your expenses",
            "action_label": "Add Expense"
          },
          "views": [
            {
              "name": "Spreadsheet",
              "layout": "spreadsheet"
            },
            {
              "name": "Table",
              "layout": "table"
            }
          ],
          "quick_filters": [
            {
              "field": "category",
              "label": "Category",
              "options": ["food", "transport", "utilities", "rent", "entertainment", "healthcare", "shopping", "travel", "education", "other"]
            },
            {
              "field": "status",
              "label": "Status",
              "options": ["pending", "approved", "rejected", "reimbursed"]
            }
          ],
          "default_sort": {
            "field": "date",
            "direction": "desc"
          },
          "searchable_fields": [
            "description",
            "vendor",
            "category"
          ],
          "row_actions": [
            {"name": "Edit", "icon": "Pencil", "action": "edit"},
            {"name": "View", "icon": "Eye", "action": "view"},
            {"name": "Delete", "icon": "Trash2", "action": "delete", "confirm": true}
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": ["date", "description", "category", "amount", "payment_method", "vendor", "receipt", "notes", "status"],
          "required_fields": ["date", "description", "category", "amount"]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": ["date", "description", "category", "amount", "payment_method", "vendor", "receipt", "notes", "status"],
          "required_fields": ["date", "description", "category", "amount"],
          "prefilled": true
        },
        "detail_view": {
          "route": "/expenses/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": ["description"],
            "badge_fields": ["status"]
          },
          "primary_fields": ["date", "description", "category", "amount", "payment_method", "vendor"],
          "tabs": [
            {
              "name": "Details",
              "fields": ["date", "description", "category", "amount", "payment_method", "vendor", "receipt", "notes", "status"]
            }
          ]
        }
      }
    },
    {
      "name": "Category",
      "table": "categories",
      "description": "Expense category with budget limits",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "name",
          "db_type": "VARCHAR(100) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Category name"
        },
        {
          "name": "budget_limit",
          "db_type": "NUMERIC(12,2)",
          "ts_type": "number",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "currency",
          "placeholder": "0.00",
          "help_text": "Monthly budget limit for this category"
        },
        {
          "name": "color",
          "db_type": "VARCHAR(20)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "#3b82f6",
          "help_text": "Color hex code for charts"
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": ["name", "budget_limit", "color"],
          "filters": [],
          "empty_state": {
            "icon": "Tag",
            "heading": "No categories yet",
            "subtext": "Create expense categories",
            "action_label": "Add Category"
          },
          "views": [{"name": "Table", "layout": "table"}],
          "default_sort": {"field": "name", "direction": "asc"},
          "searchable_fields": ["name"],
          "row_actions": [
            {"name": "Edit", "icon": "Pencil", "action": "edit"},
            {"name": "Delete", "icon": "Trash2", "action": "delete", "confirm": true}
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": ["name", "budget_limit", "color"],
          "required_fields": ["name"]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": ["name", "budget_limit", "color"],
          "required_fields": ["name"],
          "prefilled": true
        },
        "detail_view": {
          "route": "/categories/:id",
          "layout": "tabbed",
          "header": {"title_fields": ["name"], "badge_fields": []},
          "primary_fields": ["name", "budget_limit", "color"],
          "tabs": [{"name": "Overview", "fields": ["name", "budget_limit", "color"]}]
        }
      }
    }
  ],
  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Expenses",
      "route": "/expenses",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Receipt",
      "entity": "Expense"
    },
    {
      "name": "Categories",
      "route": "/categories",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Tag",
      "entity": "Category"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total Expenses",
        "entity": "Expense",
        "method": "count",
        "icon": "Receipt",
        "color": "blue"
      },
      {
        "label": "Total Spent",
        "entity": "Expense",
        "method": "sum",
        "field": "amount",
        "icon": "DollarSign",
        "color": "green"
      },
      {
        "label": "Pending",
        "entity": "Expense",
        "method": "count",
        "filter": {"field": "status", "value": "pending"},
        "icon": "Clock",
        "color": "amber"
      },
      {
        "label": "Categories",
        "entity": "Category",
        "method": "count",
        "icon": "Tag",
        "color": "purple"
      }
    ]
  },
  "design_system": {
    "theme": "light",
    "colors": {
      "primary": "#3b82f6",
      "secondary": "#64748b",
      "background": "#ffffff",
      "surface": "#f8fafc",
      "text": "#0f172a",
      "muted": "#94a3b8"
    },
    "spacing": {
      "page_padding": "24px",
      "card_padding": "16px",
      "gap": "16px"
    },
    "buttons": {
      "primary": {
        "bg": "bg-blue-500",
        "text": "text-white",
        "hover": "hover:bg-blue-600"
      }
    },
    "table": {
      "header_bg": "bg-gray-50",
      "row_hover": "hover:bg-gray-50",
      "border": "border-gray-200"
    },
    "typography": {
      "heading": "text-gray-900 font-semibold",
      "body": "text-gray-700",
      "muted": "text-gray-400"
    }
  },
  "pagination": {
    "type": "cursor",
    "default_page_size": 25,
    "max_page_size": 100
  }
}
