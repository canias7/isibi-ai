          "route": "/clients/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "company_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "company_name",
            "contact_name",
            "email",
            "monthly_fee"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "company_name",
                "contact_name",
                "email",
                "monthly_fee",
                "status"
