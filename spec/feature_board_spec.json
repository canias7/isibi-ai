      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Features",
      "route": "/features",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Feature"
    },
    {
      "name": "Comments",
      "route": "/comments",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
