        "list_view": {
          "layout": "table",
          "columns": [
            "property_address",
            "client_name",
            "listing_agent",
            "style",
            "budget",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Projects yet",
            "subtext": "Create your first project",
            "action_label": "Add Project"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "property_address",
            "client_name",
            "listing_agent",
            "style",
            "budget",
            "status"
          ],
          "required_fields": [
            "property_address",
            "client_name"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "property_address",
            "client_name",
            "listing_agent",
            "style",
            "budget",
            "status"
          ],
          "required_fields": [
            "property_address",
            "client_name"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/projects/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "property_address"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "property_address",
            "client_name",
            "listing_agent",
            "style"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "property_address",
                "client_name",
                "listing_agent",
                "style",
                "budget",
                "status"
              ]
            }
          ]
        }
