  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Motorcycle",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Total Price",
        "entity": "Motorcycle",
        "method": "sum",
        "field": "price",
        "icon": "DollarSign",
        "color": "amber"
      },
      {
        "label": "Total Services",
        "entity": "Service",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
