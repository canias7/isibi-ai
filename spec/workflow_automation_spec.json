      {
        "label": "Total Workflows",
        "query": "COUNT(*) FROM workflows",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Total Total Runs",
        "query": "SUM(total_runs) FROM workflows",
        "icon": "DollarSign",
        "format": "currency",
        "color": "green"
      },
      {
        "label": "Active Workflows",
        "query": "COUNT(*) FROM workflows WHERE category = 'approval'",
        "icon": "CheckCircle",
        "color": "emerald"
      },
      {
        "label": "This Week",
        "query": "COUNT(*) FROM workflows WHERE created_at >= date_trunc('week', NOW())",
        "icon": "Calendar",
        "color": "purple"
      },
      {
        "label": "Total Steps",
        "query": "COUNT(*) FROM workflow_steps",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Active Steps",
        "query": "COUNT(*) FROM workflow_steps WHERE step_type = 'action'",
        "icon": "CheckCircle",
        "color": "emerald"
      }
    ]
