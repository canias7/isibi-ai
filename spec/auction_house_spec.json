      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "title",
            "category",
            "estimate_low",
            "estimate_high",
            "current_bid",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Lots yet",
            "subtext": "Add lot",
            "action_label": "Add Lot"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "category",
            "estimate_low",
            "estimate_high",
            "current_bid",
            "status"
          ],
          "required_fields": [
            "title",
            "category"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "category",
            "estimate_low",
            "estimate_high",
            "current_bid",
            "status"
          ],
          "required_fields": [
            "title",
            "category"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/lots/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "title"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "title",
            "category",
            "estimate_low",
            "estimate_high"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "title",
                "category",
                "estimate_low",
                "estimate_high",
                "current_bid",
                "status"
              ]
            }
          ]
        }
      }
    },
