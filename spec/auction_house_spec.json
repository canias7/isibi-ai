  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Lots",
      "route": "/lots",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
