            "scheduled",
            "full",
            "completed",
            "cancelled"
          ],
          "badge_colors": {
            "scheduled": "pink",
            "full": "blue",
            "completed": "green",
            "cancelled": "amber"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "title",
            "instructor",
            "date",
            "capacity",
            "price",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Classs yet",
            "subtext": "Add class",
            "action_label": "Add Class"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "instructor",
            "date",
            "capacity",
            "price",
            "status"
          ],
          "required_fields": [
            "title",
            "instructor"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "instructor",
            "date",
            "capacity",
            "price",
            "status"
          ],
          "required_fields": [
            "title",
            "instructor"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/classes/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "title"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "title",
            "instructor",
            "date",
            "capacity"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "title",
                "instructor",
                "date",
                "capacity",
                "price",
                "status"
              ]
            }
          ]
        }
      }
    },
