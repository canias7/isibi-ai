  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "ChangeRequest",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Completed ChangeRequests",
        "entity": "ChangeRequest",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "approved"
        },
        "icon": "CheckCircle",
        "color": "emerald"
      },
      {
        "label": "Total Approvals",
        "entity": "Approval",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      }
    ]
