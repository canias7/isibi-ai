  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "ChangeRequests",
      "route": "/change_requests",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "ChangeRequest"
    },
    {
      "name": "Approvals",
      "route": "/approvals",
      "component": "EntityListPage",
      "layout": "app",
