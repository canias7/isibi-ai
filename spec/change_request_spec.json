          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No ChangeRequests",
            "subtext": "Add ChangeRequest",
            "action_label": "Add ChangeRequest"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "submitted",
                "assessing",
                "approved",
                "implementing",
                "completed",
                "rejected"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "title",
            "requester"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Approved",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "approved"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "requester",
            "type",
            "impact",
            "status"
          ],
          "required_fields": [
            "title",
            "requester"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "requester",
            "type",
            "impact",
            "status"
          ],
          "required_fields": [
            "title",
            "requester"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/change_requests/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "title"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "title",
            "requester",
            "type",
            "impact"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "title",
                "requester",
                "type",
                "impact",
                "status"
              ]
            }
          ]
        }
      }
    },
