        "list_view": {
          "layout": "table",
          "columns": [
            "title",
            "client_name",
            "type",
            "duration_sec",
            "budget",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Projects yet",
            "subtext": "Create your first project",
            "action_label": "Add Project"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "client_name",
            "type",
            "duration_sec",
            "budget",
            "status"
          ],
          "required_fields": [
            "title",
            "client_name"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "client_name",
            "type",
            "duration_sec",
            "budget",
            "status"
          ],
          "required_fields": [
            "title",
            "client_name"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/projects/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "title"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "title",
            "client_name",
            "type",
            "duration_sec"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "title",
                "client_name",
                "type",
                "duration_sec",
                "budget",
                "status"
              ]
            }
          ]
        }
      }
