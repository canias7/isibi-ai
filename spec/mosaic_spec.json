            "client",
            "type",
            "material",
            "sqft"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "client",
                "type",
                "material",
                "sqft",
                "price",
                "status"
              ]
            }
          ]
        }
      }
