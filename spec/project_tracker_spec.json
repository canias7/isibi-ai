{
  "_meta": {
    "app_name": "Project Tracker",
    "description": "Project tracking tool"
  },
  "entities": [
    {
      "name": "Project",
      "table": "projects",
      "description": "Project",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Enter name",
          "help_text": "Full name"
        },
        {
          "name": "owner_name",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "deadline",
          "db_type": "DATE",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "date_input",
          "display_component": "date"
        },
        {
          "name": "budget",
          "db_type": "NUMERIC(12,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text",
          "validation": {
            "min": 0,
            "message": "Budget must be a positive number"
          },
          "placeholder": "0.00",
          "help_text": "Budget in USD"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "planning",
            "active",
            "on_hold",
            "completed",
            "cancelled"
          ],
          "badge_colors": {
            "planning": "pink",
            "active": "blue",
            "on_hold": "green",
            "completed": "amber",
            "cancelled": "purple"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "owner_name",
            "deadline",
            "budget",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Projects yet",
            "subtext": "Create your first project",
            "action_label": "Add Project"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            },
            {
              "name": "Calendar",
              "layout": "calendar",
              "date_field": "deadline"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "planning",
                "active",
                "on_hold",
                "completed",
                "cancelled"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "name",
            "owner_name"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Completed",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "completed"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "owner_name",
            "deadline",
            "budget",
            "status"
          ],
          "required_fields": [
            "name",
            "owner_name"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "owner_name",
            "deadline",
            "budget",
            "status"
          ],
          "required_fields": [
            "name",
            "owner_name"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/projects/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "owner_name",
            "deadline",
            "budget"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "owner_name",
                "deadline",
                "budget",
                "status"
              ]
            }
          ]
        }
      }
    },
