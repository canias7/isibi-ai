            "name",
            "phone",
            "skills",
            "availability",
            "status"
          ],
          "required_fields": [
            "name",
            "phone"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/workers/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "phone",
            "availability",
            "status"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "phone",
                "availability",
                "status"
              ]
            }
          ]
        }
      }
