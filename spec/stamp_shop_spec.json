            "name",
            "country",
            "year",
            "condition",
            "price",
            "stock"
          ],
          "required_fields": [
            "name",
            "country"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "country",
            "year",
            "condition",
            "price",
            "stock"
          ],
          "required_fields": [
            "name",
            "country"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/stamps/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "country",
            "year",
            "condition"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "country",
                "year",
                "condition",
                "price",
                "stock"
              ]
            }
          ]
        }
      }
