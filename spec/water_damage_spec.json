{
  "_meta": {
    "app_name": "Water Damage",
    "description": "Water Damage management"
  },
  "entities": [
    {
      "name": "Job",
      "table": "jobs",
      "description": "Job",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "customer",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "address",
          "db_type": "VARCHAR(500)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "source",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "pipe_burst",
            "flood",
            "roof_leak",
            "appliance",
            "sewer",
            "storm"
          ],
          "badge_colors": {
            "pipe_burst": "pink",
            "flood": "blue",
            "roof_leak": "green",
            "appliance": "amber",
            "sewer": "purple",
            "storm": "red"
          }
        },
        {
          "name": "category",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "clean",
            "gray",
            "black"
          ],
          "badge_colors": {
            "clean": "pink",
            "gray": "blue",
            "black": "green"
          }
        },
        {
          "name": "rooms_affected",
          "db_type": "INTEGER",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "price",
          "db_type": "NUMERIC(14,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": false,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "emergency",
            "extraction",
            "drying",
            "monitoring",
            "restoration",
            "done"
          ],
          "badge_colors": {
            "emergency": "pink",
            "extraction": "blue",
            "drying": "green",
            "monitoring": "amber",
            "restoration": "purple",
            "done": "red"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "customer",
            "address",
            "source",
            "category",
            "rooms_affected",
            "price"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Jobs yet",
            "subtext": "Add job",
            "action_label": "Add Job"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer",
            "address",
            "source",
            "category",
            "rooms_affected",
            "price",
            "status"
          ],
          "required_fields": [
            "customer",
            "address"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer",
            "address",
            "source",
            "category",
            "rooms_affected",
            "price",
            "status"
          ],
          "required_fields": [
            "customer",
            "address"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/jobs/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "customer"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "customer",
            "address",
            "source",
            "category"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "customer",
                "address",
                "source",
                "category",
                "rooms_affected",
                "price"
              ]
            }
          ]
        }
      }
    }
  ],
  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Jobs",
      "route": "/jobs",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Job"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Job",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      }
    ]
  },
  "design_system": {
    "theme": "light",
    "colors": {
      "primary": "#ec4899",
      "secondary": "#64748b",
      "background": "#ffffff",
      "surface": "#f8fafc",
      "text": "#0f172a",
      "muted": "#94a3b8"
    },
    "spacing": {
      "page_padding": "24px",
      "card_padding": "16px",
      "gap": "16px"
    },
    "buttons": {
      "primary": {
        "bg": "bg-pink-500",
        "text": "text-white",
        "hover": "hover:bg-pink-600"
      }
    },
    "table": {
      "header_bg": "bg-gray-50",
      "row_hover": "hover:bg-gray-50",
      "border": "border-gray-200"
    },
    "typography": {
      "heading": "text-gray-900 font-semibold",
      "body": "text-gray-700",
      "muted": "text-gray-400"
    }
  },
  "pagination": {
    "type": "cursor",
    "default_page_size": 25,
    "max_page_size": 100
  }
}