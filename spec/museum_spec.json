          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "planning",
                "installing",
                "open",
                "closing",
                "archived"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "title",
            "gallery"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Archived",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "archived"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "gallery",
            "type",
            "start_date",
            "end_date",
            "status"
          ],
          "required_fields": [
            "title",
            "gallery"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "gallery",
            "type",
            "start_date",
            "end_date",
            "status"
          ],
          "required_fields": [
            "title",
            "gallery"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/exhibits/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "title"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "title",
            "gallery",
            "type",
            "start_date"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "title",
                "gallery",
                "type",
                "start_date",
                "end_date",
                "status"
              ]
            }
          ]
        }
      }
    },
