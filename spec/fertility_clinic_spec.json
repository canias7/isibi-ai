{
  "_meta": {
    "app_name": "Fertility Clinic",
    "description": "Fertility treatment"
  },
  "entities": [
    {
      "name": "Patient",
      "table": "patients",
      "description": "Patient",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Enter name",
          "help_text": "Full name"
        },
        {
          "name": "partner_name",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "phone",
          "db_type": "VARCHAR(20)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "validation": {
            "pattern": "^\\+?[\\d\\s\\-\\(\\)]{7,20}$",
            "message": "Enter a valid phone number"
          },
          "placeholder": "+1 (555) 000-0000",
          "help_text": "Contact phone number"
        },
        {
          "name": "email",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "validation": {
            "pattern": "^[^@]+@[^@]+\\.[^@]+$",
            "message": "Enter a valid email address"
          },
          "placeholder": "email@example.com",
          "help_text": "Primary email address"
        },
        {
          "name": "date_of_birth",
          "db_type": "DATE",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "date_picker",
          "display_component": "date"
        },
        {
          "name": "address",
          "db_type": "TEXT",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "textarea",
          "display_component": "text",
          "placeholder": "Street, City, State, ZIP",
          "help_text": "Full mailing address"
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "partner_name",
            "phone"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Patients yet",
            "subtext": "Create your first patient",
            "action_label": "Add Patient"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Calendar",
              "layout": "calendar",
              "date_field": "date_of_birth"
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "name",
            "partner_name",
            "phone",
            "email",
            "address"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "partner_name",
            "phone"
          ],
          "required_fields": [
            "name",
            "partner_name"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "partner_name",
            "phone"
          ],
          "required_fields": [
            "name",
            "partner_name"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/patients/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "partner_name",
            "phone"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "partner_name",
                "phone"
              ]
            }
          ]
        }
      }
    },
    {
      "name": "Cycle",
      "table": "cycles",
      "description": "Treatment cycle",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "patient_name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "type",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "ivf",
            "iui",
            "monitoring",
            "egg_freezing"
          ],
          "badge_colors": {
            "ivf": "pink",
            "iui": "blue",
            "monitoring": "green",
            "egg_freezing": "amber"
          }
        },
        {
          "name": "start_date",
          "db_type": "DATE",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "date_input",
          "display_component": "date"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "planning",
            "active",
            "transfer",
            "pregnant",
            "unsuccessful"
          ],
          "badge_colors": {
            "planning": "pink",
            "active": "blue",
            "transfer": "green",
            "pregnant": "amber",
            "unsuccessful": "purple"
          }
        },
        {
          "name": "description",
          "db_type": "TEXT",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "textarea",
          "display_component": "text",
          "placeholder": "Enter description...",
          "help_text": "Brief description"
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "patient_name",
            "type",
            "start_date",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Cycles yet",
            "subtext": "Create your first cycle",
            "action_label": "Add Cycle"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            },
            {
              "name": "Calendar",
              "layout": "calendar",
              "date_field": "start_date"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "planning",
                "active",
                "transfer",
                "pregnant",
                "unsuccessful"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "patient_name",
            "description"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "patient_name",
            "type",
            "start_date",
            "status"
          ],
          "required_fields": [
            "patient_name",
            "type"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "patient_name",
            "type",
            "start_date",
            "status"
          ],
          "required_fields": [
            "patient_name",
            "type"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/cycles/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "patient_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "patient_name",
            "type",
            "start_date",
            "status"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "patient_name",
                "type",
                "start_date",
                "status"
              ]
            }
          ]
        }
      }
    }
  ],
  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Patients",
      "route": "/patients",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Patient"
    },
    {
      "name": "Cycles",
      "route": "/cycles",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Cycle"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total Patients",
        "entity": "Patient",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Total Cycles",
        "entity": "Cycle",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Active Cycles",
        "entity": "Cycle",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "active"
        },
        "icon": "Activity",
        "color": "green"
      }
    ]
  },
  "design_system": {
    "theme": "light",
    "colors": {
      "primary": "#ec4899",
      "secondary": "#64748b",
      "background": "#ffffff",
      "surface": "#f8fafc",
      "text": "#0f172a",
      "muted": "#94a3b8"
    },
    "spacing": {
      "page_padding": "24px",
      "card_padding": "16px",
      "gap": "16px"
    },
    "buttons": {
      "primary": {
        "bg": "bg-pink-500",
        "text": "text-white",
        "hover": "hover:bg-pink-600"
      }
    },
    "table": {
      "header_bg": "bg-gray-50",
      "row_hover": "hover:bg-gray-50",
      "border": "border-gray-200"
    },
    "typography": {
      "heading": "text-gray-900 font-semibold",
      "body": "text-gray-700",
      "muted": "text-gray-400"
    }
  },
  "pagination": {
    "type": "cursor",
    "default_page_size": 25,
    "max_page_size": 100
  }
}
