      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "tag",
            "category",
            "location",
            "assigned_to",
            "purchase_date"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Assets yet",
            "subtext": "Add asset",
            "action_label": "Add Asset"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "tag",
            "category",
            "location",
            "assigned_to",
            "purchase_date",
            "value",
            "status"
          ],
          "required_fields": [
            "name",
            "tag"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "tag",
            "category",
            "location",
            "assigned_to",
            "purchase_date",
            "value",
            "status"
          ],
          "required_fields": [
            "name",
            "tag"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/assets/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "tag",
            "category",
            "location"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "tag",
                "category",
                "location",
                "assigned_to",
                "purchase_date"
              ]
            }
          ]
        }
      }
