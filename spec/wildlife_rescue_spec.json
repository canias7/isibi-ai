      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Animals",
      "route": "/animals",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Animal"
    },
    {
      "name": "Treatments",
      "route": "/treatments",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
