{
  "_meta": {
    "app_name": "Wildlife Rescue",
    "description": "Wildlife rehabilitation"
  },
  "entities": [
    {
      "name": "Animal",
      "table": "animals",
      "description": "Rescued animal",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "species",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "intake_date",
          "db_type": "DATE",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "date_input",
          "display_component": "date"
        },
        {
          "name": "location_found",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "condition",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "critical",
            "serious",
            "stable",
            "recovering",
            "releasable"
          ],
          "badge_colors": {
            "critical": "pink",
            "serious": "blue",
            "stable": "green",
            "recovering": "amber",
            "releasable": "purple"
          }
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "intake",
            "treatment",
            "rehab",
            "released",
            "permanent",
            "deceased"
          ],
          "badge_colors": {
            "intake": "pink",
            "treatment": "blue",
            "rehab": "green",
            "released": "amber",
            "permanent": "purple",
            "deceased": "red"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "species",
            "intake_date",
            "location_found",
            "condition",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Animals yet",
            "subtext": "Create your first animal",
            "action_label": "Add Animal"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "species",
            "intake_date",
            "location_found",
            "condition",
            "status"
          ],
          "required_fields": [
            "species",
            "intake_date"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "species",
            "intake_date",
            "location_found",
            "condition",
            "status"
          ],
          "required_fields": [
            "species",
            "intake_date"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/animals/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "species"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "species",
            "intake_date",
            "location_found",
            "condition"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "species",
                "intake_date",
                "location_found",
                "condition",
                "status"
              ]
            }
          ]
        }
      }
    },
