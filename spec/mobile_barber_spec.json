{
  "_meta": {
    "app_name": "Mobile Barber ",
    "description": "Mobile Barber  management"
  },
  "entities": [
    {
      "name": "Appointment",
      "table": "appointments",
      "description": "Appointment",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
