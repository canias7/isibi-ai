            "client",
            "provider",
            "date",
            "time",
            "address",
            "price"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Appointments yet",
            "subtext": "Add appointment",
            "action_label": "Add Appointment"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client",
            "provider",
            "date",
            "time",
            "address",
            "price",
            "status"
          ],
          "required_fields": [
            "client",
            "provider"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client",
            "provider",
            "date",
            "time",
            "address",
            "price",
            "status"
          ],
          "required_fields": [
            "client",
            "provider"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/appointments/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "client"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "client",
            "provider",
            "date",
            "time"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "client",
                "provider",
                "date",
                "time",
                "address",
                "price"
              ]
            }
          ]
        }
      }
    },
