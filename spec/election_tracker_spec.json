          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "party",
            "office",
            "district"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "party",
                "office",
                "district",
                "status"
              ]
            }
          ]
        }
      }
