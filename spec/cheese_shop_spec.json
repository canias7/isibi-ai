{
  "_meta": {
    "app_name": "Cheese Shop",
    "description": "Cheese Shop management"
  },
  "entities": [
    {
      "name": "Cheese",
      "table": "cheeses",
      "description": "Cheese",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Enter name",
          "help_text": "Full name"
        },
        {
          "name": "type",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "hard",
            "soft",
            "blue",
            "fresh",
            "aged",
            "smoked"
          ],
          "badge_colors": {
            "hard": "pink",
            "soft": "blue",
            "blue": "green",
            "fresh": "amber",
            "aged": "purple",
            "smoked": "red"
          }
        },
        {
          "name": "origin",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "price_lb",
          "db_type": "NUMERIC(10,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "stock_lbs",
          "db_type": "NUMERIC(10,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "type",
            "origin",
            "price_lb",
            "stock_lbs"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Cheeses yet",
            "subtext": "Add cheese",
            "action_label": "Add Cheese"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "name",
            "origin"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "type",
            "origin",
            "price_lb",
            "stock_lbs"
          ],
          "required_fields": [
            "name",
            "type"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "type",
            "origin",
            "price_lb",
            "stock_lbs"
          ],
          "required_fields": [
            "name",
            "type"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/cheeses/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "type",
            "origin",
            "price_lb"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "type",
                "origin",
                "price_lb",
                "stock_lbs"
              ]
            }
          ]
        }
      }
    },
    {
      "name": "Order",
      "table": "orders",
      "description": "Order",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "items",
          "db_type": "TEXT",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": false,
          "show_in_form": true,
          "input_component": "textarea",
          "display_component": "text"
        },
        {
          "name": "total",
          "db_type": "NUMERIC(10,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text",
          "validation": {
            "min": 0,
            "message": "Total must be a positive number"
          },
          "placeholder": "0.00",
          "help_text": "Total amount in USD"
        },
        {
          "name": "quantity",
          "db_type": "INTEGER",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text",
          "validation": {
            "min": 0,
            "message": "Quantity must be a positive number"
          },
          "placeholder": "1",
          "help_text": "Number of units"
        },
        {
          "name": "order_date",
          "db_type": "DATE",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "date_picker",
          "display_component": "date"
        },
        {
          "name": "notes",
          "db_type": "TEXT",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "textarea",
          "display_component": "text",
          "placeholder": "Additional notes...",
          "help_text": "Internal notes (not visible to customers)"
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "total"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Orders yet",
            "subtext": "Add order",
            "action_label": "Add Order"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Calendar",
              "layout": "calendar",
              "date_field": "order_date"
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "items",
            "total"
          ],
          "required_fields": [
            "items",
            "total"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "items",
            "total"
          ],
          "required_fields": [
            "items",
            "total"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/orders/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "items"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "total"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "total"
              ]
            }
          ]
        }
      }
    }
  ],
  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Cheeses",
      "route": "/cheeses",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Cheese"
    },
    {
      "name": "Orders",
      "route": "/orders",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Order"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Cheese",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Total Price Lb",
        "entity": "Cheese",
        "method": "sum",
        "field": "price_lb",
        "icon": "DollarSign",
        "color": "amber"
      },
      {
        "label": "Total Orders",
        "entity": "Order",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Total Total",
        "entity": "Order",
        "method": "sum",
        "field": "total",
        "icon": "DollarSign",
        "color": "amber"
      }
    ]
  },
  "design_system": {
    "theme": "light",
    "colors": {
      "primary": "#ec4899",
      "secondary": "#64748b",
      "background": "#ffffff",
      "surface": "#f8fafc",
      "text": "#0f172a",
      "muted": "#94a3b8"
    },
    "spacing": {
      "page_padding": "24px",
      "card_padding": "16px",
      "gap": "16px"
    },
    "buttons": {
      "primary": {
        "bg": "bg-pink-500",
        "text": "text-white",
        "hover": "hover:bg-pink-600"
      }
    },
    "table": {
      "header_bg": "bg-gray-50",
      "row_hover": "hover:bg-gray-50",
      "border": "border-gray-200"
    },
    "typography": {
      "heading": "text-gray-900 font-semibold",
      "body": "text-gray-700",
      "muted": "text-gray-400"
    }
  },
  "pagination": {
    "type": "cursor",
    "default_page_size": 25,
    "max_page_size": 100
  }
}
