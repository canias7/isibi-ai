          "required_fields": [
            "name",
            "type"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "type",
            "location",
            "revenue_today",
            "status"
          ],
          "required_fields": [
            "name",
            "type"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/machines/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "type",
            "location",
            "revenue_today"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "type",
                "location",
                "revenue_today",
                "status"
              ]
            }
          ]
        }
      }
