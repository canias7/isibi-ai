        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "type",
            "location",
            "revenue_today",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Machines yet",
            "subtext": "Create your first machine",
            "action_label": "Add Machine"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "type",
            "location",
            "revenue_today",
            "status"
