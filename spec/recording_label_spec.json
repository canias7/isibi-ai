        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "genre",
            "contract_status",
            "royalty_pct"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Artists yet",
            "subtext": "Create your first artist",
            "action_label": "Add Artist"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "name",
            "description"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "genre",
            "contract_status",
            "royalty_pct"
          ],
          "required_fields": [
            "name",
            "genre"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "genre",
            "contract_status",
            "royalty_pct"
          ],
          "required_fields": [
            "name",
            "genre"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/artists/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "genre",
            "contract_status",
            "royalty_pct"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "genre",
                "contract_status",
                "royalty_pct"
              ]
            }
          ]
        }
      }
    },
