            "pop",
            "rock",
            "hip_hop",
            "rnb",
            "electronic",
            "country",
            "latin",
            "jazz",
            "classical"
          ],
          "badge_colors": {
            "pop": "pink",
            "rock": "red",
            "hip_hop": "purple",
            "rnb": "blue",
            "electronic": "blue",
            "country": "green",
            "latin": "amber",
            "jazz": "amber",
            "classical": "slate"
          }
