            "icon": "Box",
            "heading": "No Webhooks yet",
            "subtext": "Add webhook",
            "action_label": "Add Webhook"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "url",
            "events",
            "secret",
            "failures",
            "status"
          ],
