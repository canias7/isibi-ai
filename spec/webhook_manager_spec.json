            "name",
            "url"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "url",
            "events",
            "secret",
            "failures",
            "status"
          ],
          "required_fields": [
            "name",
            "url"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/webhooks/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "url",
            "secret",
            "failures"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "url",
                "secret",
                "failures",
                "status"
              ]
            }
          ]
        }
      }
    },
