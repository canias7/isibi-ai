          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "requested",
            "assigned",
            "running",
            "completed",
            "cancelled"
          ],
          "badge_colors": {
            "requested": "pink",
            "assigned": "blue",
            "running": "green",
            "completed": "amber",
            "cancelled": "purple"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "client_name",
            "type",
            "runner_name",
            "price",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Tasks yet",
            "subtext": "Add task",
            "action_label": "Add Task"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client_name",
            "type",
            "description",
            "runner_name",
            "price",
            "status"
          ],
          "required_fields": [
            "client_name",
            "type"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client_name",
            "type",
            "description",
            "runner_name",
            "price",
            "status"
          ],
          "required_fields": [
            "client_name",
            "type"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/tasks/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "client_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "client_name",
            "type",
            "runner_name",
            "price"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "client_name",
                "type",
                "runner_name",
                "price",
                "status"
              ]
            }
          ]
        }
      }
    },
