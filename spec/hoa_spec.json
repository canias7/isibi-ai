        "list_view": {
          "layout": "table",
          "columns": [
            "address",
            "owner_name",
            "unit",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Propertys yet",
            "subtext": "Create your first property",
            "action_label": "Add Property"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "address",
            "owner_name",
            "unit",
            "status"
          ],
