            "address",
            "owner_name"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "address",
            "owner_name",
            "unit",
            "status"
          ],
          "required_fields": [
            "address",
            "owner_name"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/properties/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "address"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "address",
            "owner_name",
            "unit",
            "status"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "address",
                "owner_name",
                "unit",
                "status"
              ]
