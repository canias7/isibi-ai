        "list_view": {
          "layout": "table",
          "columns": [
            "shipper",
            "origin",
            "destination",
            "weight_lbs",
            "type",
            "rate"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Loads yet",
            "subtext": "Add load",
            "action_label": "Add Load"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "shipper",
            "origin",
            "destination",
            "weight_lbs",
            "type",
            "rate",
            "status"
          ],
          "required_fields": [
            "shipper",
            "origin"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "shipper",
            "origin",
            "destination",
            "weight_lbs",
            "type",
            "rate",
            "status"
          ],
          "required_fields": [
            "shipper",
            "origin"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/loads/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "shipper"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "shipper",
            "origin",
            "destination",
            "weight_lbs"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "shipper",
                "origin",
                "destination",
                "weight_lbs",
                "type",
                "rate"
              ]
            }
          ]
        }
      }
    },
