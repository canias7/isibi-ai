        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "address",
            "owner_name",
            "opened_date",
            "monthly_revenue",
            "royalty_pct"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Locations yet",
            "subtext": "Create your first location",
            "action_label": "Add Location"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            },
            {
              "name": "Calendar",
              "layout": "calendar",
              "date_field": "opened_date"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "open",
                "under_construction",
                "temporarily_closed",
                "permanently_closed"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "name",
            "address",
            "owner_name"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "address",
            "owner_name",
            "opened_date",
            "monthly_revenue",
            "royalty_pct",
            "status"
          ],
          "required_fields": [
            "name",
            "address"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "address",
            "owner_name",
            "opened_date",
            "monthly_revenue",
            "royalty_pct",
            "status"
          ],
          "required_fields": [
            "name",
            "address"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/locations/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "address",
            "owner_name",
            "opened_date"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "address",
                "owner_name",
                "opened_date",
                "monthly_revenue",
                "royalty_pct",
                "status"
              ]
            }
          ]
        }
      }
    },
