            "name",
            "age",
            "parent_name",
            "parent_phone",
            "session",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Campers yet",
            "subtext": "Add camper",
            "action_label": "Add Camper"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "registered",
                "paid",
                "attended",
                "cancelled"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "name",
            "parent_name",
            "parent_phone",
            "session"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Paid",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "paid"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "age",
            "parent_name",
            "parent_phone",
            "session",
            "status"
          ],
          "required_fields": [
            "name",
            "age"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "age",
            "parent_name",
            "parent_phone",
            "session",
            "status"
          ],
          "required_fields": [
            "name",
            "age"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/campers/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "age",
            "parent_name",
            "parent_phone"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "age",
                "parent_name",
                "parent_phone",
                "session",
                "status"
              ]
            }
          ]
        }
      }
    },
