  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Camper",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Completed Campers",
        "entity": "Camper",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "paid"
        },
        "icon": "CheckCircle",
        "color": "emerald"
      },
      {
        "label": "Total Activitys",
        "entity": "Activity",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      }
    ]
  },
