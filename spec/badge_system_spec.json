{
  "_meta": {
    "app_name": "Badge System",
    "description": "Badge System management"
  },
  "entities": [
    {
      "name": "Badge",
      "table": "badges",
      "description": "Badge",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "number",
          "db_type": "VARCHAR(20) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "holder",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "type",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "employee",
            "contractor",
            "visitor",
            "temp",
            "executive"
          ],
          "badge_colors": {
            "employee": "pink",
            "contractor": "blue",
            "visitor": "green",
            "temp": "amber",
            "executive": "purple"
          }
        },
        {
          "name": "access_level",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "basic",
            "standard",
            "restricted",
            "all_access"
          ],
          "badge_colors": {
            "basic": "pink",
            "standard": "blue",
            "restricted": "green",
            "all_access": "amber"
          }
        },
        {
          "name": "issued_date",
          "db_type": "DATE",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "date_input",
          "display_component": "date"
        },
        {
          "name": "expiry_date",
          "db_type": "DATE",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "date_input",
          "display_component": "date"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": false,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "active",
            "expired",
            "lost",
            "deactivated"
          ],
          "badge_colors": {
            "active": "pink",
            "expired": "blue",
            "lost": "green",
            "deactivated": "amber"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "number",
            "holder",
            "type",
            "access_level",
            "issued_date",
            "expiry_date"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Badges yet",
            "subtext": "Add badge",
            "action_label": "Add Badge"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            },
            {
              "name": "Calendar",
              "layout": "calendar",
              "date_field": "issued_date"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "active",
                "expired",
                "lost",
                "deactivated"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "number",
            "holder"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "number",
            "holder",
            "type",
            "access_level",
            "issued_date",
            "expiry_date",
            "status"
          ],
          "required_fields": [
            "number",
            "holder"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "number",
            "holder",
            "type",
            "access_level",
            "issued_date",
            "expiry_date",
            "status"
          ],
          "required_fields": [
            "number",
            "holder"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/badges/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "number"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "number",
            "holder",
            "type",
            "access_level"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "number",
                "holder",
                "type",
                "access_level",
                "issued_date",
                "expiry_date"
              ]
            }
          ]
        }
      }
    },
