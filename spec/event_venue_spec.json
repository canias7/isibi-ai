      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "capacity",
            "type",
            "hourly_rate",
            "full_day_rate"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Spaces yet",
            "subtext": "Create your first space",
            "action_label": "Add Space"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "name"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "capacity",
            "type",
            "hourly_rate",
            "full_day_rate"
          ],
          "required_fields": [
            "name",
            "capacity"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "capacity",
            "type",
            "hourly_rate",
            "full_day_rate"
          ],
          "required_fields": [
            "name",
            "capacity"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/spaces/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "capacity",
            "type",
            "hourly_rate"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "capacity",
                "type",
                "hourly_rate",
                "full_day_rate"
              ]
            }
          ]
        }
      }
    },
