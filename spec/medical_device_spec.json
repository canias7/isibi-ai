{
  "_meta": {
    "app_name": "Medical Device",
    "description": "Device tracking"
  },
  "entities": [
    {
      "name": "Device",
      "table": "devices",
      "description": "Device",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "serial_number",
          "db_type": "VARCHAR(50) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "SN-XXXXXX",
          "help_text": "Manufacturer serial number"
        },
        {
          "name": "name",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Enter name",
          "help_text": "Full name"
        },
        {
          "name": "type",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "monitor",
            "ventilator",
            "pump",
            "imaging",
            "surgical",
            "diagnostic"
          ],
          "badge_colors": {
            "monitor": "pink",
            "ventilator": "blue",
            "pump": "green",
            "imaging": "amber",
            "surgical": "purple",
            "diagnostic": "red"
          }
        },
        {
          "name": "location",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "e.g. Building A, Room 101",
          "help_text": "Physical location"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "active",
            "calibration",
            "repair",
            "retired"
          ],
          "badge_colors": {
            "active": "pink",
            "calibration": "blue",
            "repair": "green",
            "retired": "amber"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "serial_number",
            "name",
            "type",
            "location",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Devices yet",
            "subtext": "Add device",
            "action_label": "Add Device"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "active",
                "calibration",
                "repair",
                "retired"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "serial_number",
            "name",
            "location"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "serial_number",
            "name",
            "type",
            "location",
            "status"
          ],
          "required_fields": [
            "serial_number",
            "name"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "serial_number",
            "name",
            "type",
            "location",
            "status"
          ],
          "required_fields": [
            "serial_number",
            "name"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/devices/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "serial_number"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "serial_number",
            "name",
            "type",
            "location"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "serial_number",
                "name",
                "type",
                "location",
                "status"
              ]
            }
          ]
        }
      }
    },
