  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Room",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Total Hourly Rate",
        "entity": "Room",
        "method": "sum",
        "field": "hourly_rate",
        "icon": "DollarSign",
        "color": "amber"
      },
      {
        "label": "Total Bookings",
        "entity": "Booking",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Active Bookings",
        "entity": "Booking",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "booked"
        },
        "icon": "Activity",
        "color": "green"
      }
    ]
  },
  "design_system": {
