        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "capacity",
            "hourly_rate",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Rooms yet",
            "subtext": "Add your first room",
            "action_label": "Add Room"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "available",
                "occupied",
                "reserved",
                "cleaning"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "name",
            "floor"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "capacity",
            "hourly_rate",
            "status"
          ],
          "required_fields": [
            "name",
            "capacity"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "capacity",
            "hourly_rate",
            "status"
          ],
          "required_fields": [
            "name",
            "capacity"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/rooms/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "capacity",
            "hourly_rate",
            "status"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "capacity",
                "hourly_rate",
                "status"
              ]
            }
          ]
        }
      }
    },
