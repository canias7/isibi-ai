  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Courses",
      "route": "/courses",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Course"
    },
    {
      "name": "Students",
      "route": "/students",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
