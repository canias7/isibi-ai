  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Course",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Courses",
        "entity": "Course",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "scheduled"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Completed Courses",
        "entity": "Course",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "completed"
        },
        "icon": "CheckCircle",
        "color": "emerald"
      },
      {
        "label": "Total Price",
        "entity": "Course",
        "method": "sum",
        "field": "price",
        "icon": "DollarSign",
        "color": "amber"
      }
    ]
  },
