          "type": "SlideOverForm",
          "field_order": [
            "name",
            "level",
            "instructor_name",
            "dates",
            "price",
            "status"
          ],
          "required_fields": [
            "name",
            "level"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/courses/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
