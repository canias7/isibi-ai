        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "survey_title",
            "respondent_email",
            "completed",
            "score"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Responses yet",
            "subtext": "Create your first response",
            "action_label": "Add Response"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "survey_title",
            "respondent_email",
            "description"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "survey_title",
            "respondent_email",
            "completed",
            "score"
          ],
          "required_fields": [
            "survey_title",
            "respondent_email"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "survey_title",
            "respondent_email",
            "completed",
            "score"
          ],
          "required_fields": [
            "survey_title",
            "respondent_email"
          ],
          "prefilled": true
