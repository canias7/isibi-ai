        {
          "name": "scope",
          "db_type": "TEXT",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": false,
          "show_in_form": true,
          "input_component": "textarea",
          "display_component": "text"
        },
        {
          "name": "findings",
