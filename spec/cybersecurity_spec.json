  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Assessments",
      "route": "/assessments",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Assessment"
    },
    {
      "name": "Findings",
      "route": "/findings",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Finding"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Assessment",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Completed Assessments",
        "entity": "Assessment",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "closed"
        },
        "icon": "CheckCircle",
        "color": "emerald"
      },
      {
        "label": "Total Findings",
        "entity": "Finding",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Active Findings",
        "entity": "Finding",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "open"
        },
        "icon": "Activity",
        "color": "green"
      }
    ]
  },
