            "property_address",
            "buyer",
            "seller",
            "closing_date",
            "type",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Orders yet",
            "subtext": "Add order",
            "action_label": "Add Order"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            },
            {
              "name": "Calendar",
              "layout": "calendar",
              "date_field": "closing_date"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "ordered",
                "searching",
                "cleared",
                "exceptions",
                "closing",
                "recorded"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "property_address",
            "buyer",
            "seller"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "property_address",
            "buyer",
            "seller",
            "closing_date",
            "type",
            "status"
          ],
          "required_fields": [
            "property_address",
            "buyer"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "property_address",
            "buyer",
            "seller",
            "closing_date",
            "type",
            "status"
          ],
          "required_fields": [
            "property_address",
            "buyer"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/orders/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "property_address"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "property_address",
            "buyer",
            "seller",
            "closing_date"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "property_address",
                "buyer",
                "seller",
                "closing_date",
                "type",
                "status"
              ]
            }
          ]
        }
      }
    },
