  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Orders",
      "route": "/orders",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Order"
    },
    {
      "name": "Documents",
      "route": "/documents",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Document"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Order",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Total Documents",
        "entity": "Document",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Active Documents",
        "entity": "Document",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "pending"
        },
        "icon": "Activity",
        "color": "green"
      }
    ]
  },
