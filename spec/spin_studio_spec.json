            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "instructor",
            "type",
            "time"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "instructor",
                "type",
                "time",
                "bikes",
                "enrolled"
              ]
            }
          ]
        }
      }
