          "type": "SlideOverForm",
          "field_order": [
            "name",
            "instructor",
            "type",
            "time",
            "bikes",
            "enrolled"
          ],
          "required_fields": [
            "name",
            "instructor"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "instructor",
            "type",
            "time",
            "bikes",
            "enrolled"
          ],
          "required_fields": [
            "name",
            "instructor"
          ],
          "prefilled": true
        },
