  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Bookings",
      "route": "/bookings",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Booking"
    },
    {
      "name": "Events",
      "route": "/events",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Event"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Booking",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Bookings",
        "entity": "Booking",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "booked"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Completed Bookings",
        "entity": "Booking",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "completed"
        },
        "icon": "CheckCircle",
        "color": "emerald"
      },
      {
        "label": "Total Events",
        "entity": "Event",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      }
    ]
