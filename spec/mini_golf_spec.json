        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "customer_name",
            "date",
            "time",
            "players",
            "course",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Bookings yet",
            "subtext": "Add your first booking",
            "action_label": "Add Booking"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            },
            {
              "name": "Calendar",
              "layout": "calendar",
              "date_field": "date"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "booked",
                "playing",
                "completed"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "customer_name"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Completed",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "completed"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "date",
            "time",
            "players",
            "course",
            "status"
          ],
          "required_fields": [
            "customer_name",
            "date"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "date",
            "time",
            "players",
            "course",
            "status"
          ],
          "required_fields": [
            "customer_name",
            "date"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/bookings/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "customer_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "customer_name",
            "date",
            "time",
            "players"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "customer_name",
                "date",
                "time",
                "players",
                "course",
                "status"
              ]
            }
          ]
        }
      }
    },
