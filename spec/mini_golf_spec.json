            "booked",
            "playing",
            "completed"
          ],
          "badge_colors": {
            "booked": "pink",
            "playing": "blue",
            "completed": "green"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
