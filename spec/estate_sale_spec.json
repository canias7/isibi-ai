            "icon": "Box",
            "heading": "No Sales yet",
            "subtext": "Add sale",
            "action_label": "Add Sale"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "address",
            "executor",
            "sale_dates",
            "items_count",
            "total_revenue",
            "commission_pct",
            "status"
          ],
          "required_fields": [
            "address",
            "executor"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "address",
            "executor",
            "sale_dates",
            "items_count",
            "total_revenue",
            "commission_pct",
            "status"
          ],
          "required_fields": [
            "address",
            "executor"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/sales/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "address"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "address",
            "executor",
            "sale_dates",
            "items_count"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "address",
                "executor",
                "sale_dates",
                "items_count",
                "total_revenue",
                "commission_pct"
              ]
            }
          ]
        }
