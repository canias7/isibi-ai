            "title_fields": [
              "customer_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "customer_name",
            "brand",
            "model",
            "kw"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "customer_name",
                "brand",
                "model",
                "kw",
                "type",
                "fuel"
              ]
            }
          ]
        }
      }
