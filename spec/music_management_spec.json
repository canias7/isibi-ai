            "name",
            "genre",
            "monthly_listeners",
            "contract_status",
            "status"
          ],
          "required_fields": [
            "name",
            "genre"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/artists/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "genre",
            "monthly_listeners",
            "contract_status"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "genre",
                "monthly_listeners",
                "contract_status",
                "status"
              ]
            }
          ]
        }
      }
    },
