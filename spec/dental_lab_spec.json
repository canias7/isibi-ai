{
  "_meta": {
    "app_name": "Dental Lab",
    "description": "Dental prosthetics lab"
  },
  "entities": [
    {
      "name": "Case",
      "table": "cases",
      "description": "Case",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "dentist_name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "patient_id_ref",
          "db_type": "VARCHAR(100)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "type",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "crown",
            "bridge",
            "denture",
            "implant",
            "veneer",
            "retainer",
            "night_guard"
          ],
          "badge_colors": {
            "crown": "pink",
            "bridge": "blue",
            "denture": "green",
            "implant": "amber",
            "veneer": "purple",
            "retainer": "red",
            "night_guard": "slate"
          }
        },
        {
          "name": "material",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "zirconia",
            "porcelain",
            "metal",
            "acrylic",
            "composite"
          ],
          "badge_colors": {
            "zirconia": "pink",
            "porcelain": "blue",
            "metal": "green",
            "acrylic": "amber",
            "composite": "purple"
          }
        },
        {
          "name": "shade",
          "db_type": "VARCHAR(20)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "received",
            "designing",
            "milling",
            "finishing",
            "shipped"
          ],
          "badge_colors": {
            "received": "pink",
            "designing": "blue",
            "milling": "green",
            "finishing": "amber",
            "shipped": "purple"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "dentist_name",
            "patient_id_ref",
            "type",
            "material",
            "shade",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Cases yet",
            "subtext": "Add case",
            "action_label": "Add Case"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "received",
                "designing",
                "milling",
                "finishing",
                "shipped"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "dentist_name",
            "patient_id_ref",
            "shade"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "dentist_name",
            "patient_id_ref",
            "type",
            "material",
            "shade",
            "status"
          ],
          "required_fields": [
            "dentist_name",
            "patient_id_ref"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "dentist_name",
            "patient_id_ref",
            "type",
            "material",
            "shade",
            "status"
          ],
          "required_fields": [
            "dentist_name",
            "patient_id_ref"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/cases/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "dentist_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "dentist_name",
            "patient_id_ref",
            "type",
            "material"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "dentist_name",
                "patient_id_ref",
                "type",
                "material",
                "shade",
                "status"
              ]
            }
          ]
        }
      }
    },
    {
      "name": "Dentist",
