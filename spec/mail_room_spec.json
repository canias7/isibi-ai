            "icon": "Box",
            "heading": "No Packages yet",
            "subtext": "Add package",
            "action_label": "Add Package"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "tracking",
            "carrier",
            "recipient",
            "department",
            "status"
          ],
          "required_fields": [
            "tracking",
            "carrier"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "tracking",
            "carrier",
            "recipient",
            "department",
            "status"
          ],
          "required_fields": [
            "tracking",
            "carrier"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/packages/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "tracking"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "tracking",
            "carrier",
            "recipient",
            "department"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "tracking",
                "carrier",
                "recipient",
                "department",
                "status"
              ]
            }
          ]
        }
      }
    },
