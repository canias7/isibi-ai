            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "phone",
            "membership",
            "license_number"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "phone",
                "membership",
                "license_number",
                "status"
              ]
            }
          ]
        }
      }
    },
