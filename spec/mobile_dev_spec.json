          "type": "SlideOverForm",
          "field_order": [
            "client",
            "platform",
            "budget",
            "deadline",
            "status"
          ],
          "required_fields": [
            "client",
            "platform"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/projects/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "client"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "client",
            "platform",
            "budget",
            "deadline"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "client",
                "platform",
                "budget",
                "deadline",
                "status"
              ]
            }
          ]
        }
      }
    },
