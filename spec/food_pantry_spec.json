  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Clients",
      "route": "/clients",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Client"
    },
    {
      "name": "Distributions",
      "route": "/distributions",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Distribution"
    },
    {
      "name": "Donations",
      "route": "/donations",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 4,
      "sidebar_icon": "Box",
      "entity": "Donation"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total Clients",
        "entity": "Client",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Clients",
        "entity": "Client",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "active"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Total Distributions",
        "entity": "Distribution",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Total Weight Lbs",
        "entity": "Distribution",
        "method": "sum",
        "field": "weight_lbs",
        "icon": "DollarSign",
        "color": "amber"
      }
    ]
  },
