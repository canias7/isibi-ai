  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Program",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Programs",
        "entity": "Program",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "active"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Completed Programs",
        "entity": "Program",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "completed"
        },
        "icon": "CheckCircle",
