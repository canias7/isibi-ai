        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "client_name",
            "type",
            "budget",
            "deadline",
            "status"
          ],
          "required_fields": [
            "title",
            "client_name"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/projects/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "title"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "title",
            "client_name",
            "type",
            "budget"
