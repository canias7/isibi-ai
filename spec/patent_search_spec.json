          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "patentability",
            "freedom_to_operate",
            "validity",
            "landscape",
            "design"
          ],
          "badge_colors": {
            "patentability": "pink",
            "freedom_to_operate": "blue",
            "validity": "green",
            "landscape": "amber",
            "design": "purple"
