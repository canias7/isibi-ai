      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "client",
            "type",
            "jurisdiction",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Searchs yet",
            "subtext": "Add search",
            "action_label": "Add Search"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client",
            "invention",
            "type",
            "jurisdiction",
            "status"
          ],
          "required_fields": [
            "client",
            "invention"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client",
            "invention",
            "type",
            "jurisdiction",
            "status"
          ],
          "required_fields": [
            "client",
            "invention"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/searches/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "client"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "client",
            "type",
            "jurisdiction",
            "status"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "client",
                "type",
                "jurisdiction",
                "status"
              ]
            }
          ]
        }
      }
    },
