        "list_view": {
          "layout": "table",
          "columns": [
            "holder",
            "vehicle_plate",
            "lot",
            "type",
            "valid_from",
            "valid_to"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Permits yet",
            "subtext": "Add permit",
            "action_label": "Add Permit"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            },
            {
              "name": "Calendar",
              "layout": "calendar",
              "date_field": "valid_from"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "active",
                "expired",
                "revoked"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "holder",
            "vehicle_plate",
            "lot"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "holder",
            "vehicle_plate",
            "lot",
            "type",
            "valid_from",
            "valid_to",
            "status"
          ],
          "required_fields": [
            "holder",
            "vehicle_plate"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "holder",
            "vehicle_plate",
            "lot",
            "type",
            "valid_from",
            "valid_to",
            "status"
          ],
          "required_fields": [
            "holder",
            "vehicle_plate"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/permits/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "holder"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "holder",
            "vehicle_plate",
            "lot",
            "type"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "holder",
                "vehicle_plate",
                "lot",
                "type",
                "valid_from",
                "valid_to"
              ]
            }
          ]
        }
      }
    },
