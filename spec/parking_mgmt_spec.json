  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Permits",
      "route": "/permits",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Permit"
    },
    {
      "name": "Violations",
      "route": "/violations",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Violation"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Permit",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Permits",
        "entity": "Permit",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "active"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Total Violations",
        "entity": "Violation",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Completed Violations",
        "entity": "Violation",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "paid"
        },
        "icon": "CheckCircle",
        "color": "emerald"
      }
    ]
  },
