            "size",
            "price",
            "toppings"
          ],
          "required_fields": [
            "name",
            "size"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "size",
            "price",
            "toppings"
          ],
          "required_fields": [
            "name",
            "size"
          ],
          "prefilled": true
