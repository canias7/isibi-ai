        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "email",
            "phone",
            "plan",
            "classes_remaining"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Members yet",
            "subtext": "Create your first member",
            "action_label": "Add Member"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "email",
            "phone",
            "plan",
            "classes_remaining"
          ],
          "required_fields": [
            "name",
            "email"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "email",
            "phone",
            "plan",
            "classes_remaining"
          ],
          "required_fields": [
            "name",
            "email"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/members/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "email",
            "phone",
            "plan"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "email",
                "phone",
                "plan",
                "classes_remaining"
              ]
            }
          ]
        }
      }
    },
