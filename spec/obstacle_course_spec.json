            "icon": "Box",
            "heading": "No Races yet",
            "subtext": "Add race",
            "action_label": "Add Race"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "distance",
            "date",
            "location",
            "capacity",
            "status"
          ],
          "required_fields": [
            "name",
            "distance"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "distance",
            "date",
            "location",
            "capacity",
            "status"
          ],
          "required_fields": [
            "name",
            "distance"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/races/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "distance",
            "date",
            "location"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "distance",
                "date",
                "location",
                "capacity",
                "status"
              ]
            }
          ]
        }
      }
    },
