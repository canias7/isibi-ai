      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "title",
            "organizer_name",
            "category",
            "date",
            "location",
            "capacity"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Events yet",
            "subtext": "Create your first event",
            "action_label": "Add Event"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "organizer_name",
            "category",
            "date",
            "location",
            "capacity",
            "price",
            "status"
          ],
          "required_fields": [
            "title",
            "organizer_name"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "organizer_name",
            "category",
            "date",
            "location",
            "capacity",
            "price",
            "status"
          ],
          "required_fields": [
            "title",
            "organizer_name"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/events/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "title"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "title",
            "organizer_name",
            "category",
            "date"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "title",
                "organizer_name",
                "category",
                "date",
                "location",
                "capacity",
                "price",
                "status"
              ]
            }
          ]
        }
      }
