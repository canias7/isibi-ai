      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "owner",
            "registrar",
            "expiry",
            "auto_renew",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Domains yet",
            "subtext": "Add domain",
            "action_label": "Add Domain"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "owner",
            "registrar",
            "expiry",
            "auto_renew",
            "status"
          ],
          "required_fields": [
            "name",
            "owner"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "owner",
            "registrar",
            "expiry",
            "auto_renew",
            "status"
          ],
          "required_fields": [
            "name",
            "owner"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/domains/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "owner",
            "registrar",
            "expiry"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "owner",
                "registrar",
                "expiry",
                "auto_renew",
                "status"
              ]
            }
          ]
        }
      }
    },
