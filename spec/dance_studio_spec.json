  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Class",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Total Students",
        "entity": "Student",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Active Students",
        "entity": "Student",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "active"
        },
        "icon": "Activity",
        "color": "green"
      }
    ]
  },
