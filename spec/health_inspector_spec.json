          "primary_fields": [
            "establishment",
            "address",
            "type",
            "score"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "establishment",
                "address",
                "type",
                "score",
                "violations",
                "critical_violations"
              ]
            }
          ]
        }
