{
  "_meta": {
    "app_name": "Health Inspector",
    "description": "Health Inspector management"
  },
  "entities": [
    {
      "name": "Inspection",
      "table": "inspections",
      "description": "Inspection",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "establishment",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "address",
          "db_type": "VARCHAR(500)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Street, City, State, ZIP",
          "help_text": "Full mailing address"
        },
        {
          "name": "type",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "routine",
            "complaint",
            "follow_up",
            "pre_opening"
          ],
          "badge_colors": {
            "routine": "pink",
            "complaint": "blue",
            "follow_up": "green",
            "pre_opening": "amber"
          }
        },
        {
          "name": "score",
          "db_type": "INTEGER",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "violations",
          "db_type": "INTEGER DEFAULT 0",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "critical_violations",
          "db_type": "INTEGER DEFAULT 0",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "result",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": false,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "pass",
            "conditional",
            "fail",
            "closed"
          ],
          "badge_colors": {
            "pass": "pink",
            "conditional": "blue",
            "fail": "green",
            "closed": "amber"
          }
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": false,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "scheduled",
            "inspecting",
            "report",
            "follow_up",
            "closed"
          ],
          "badge_colors": {
            "scheduled": "pink",
            "inspecting": "blue",
            "report": "green",
            "follow_up": "amber",
            "closed": "purple"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "establishment",
            "address",
            "type",
            "score",
            "violations",
            "critical_violations"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Inspections yet",
            "subtext": "Add inspection",
            "action_label": "Add Inspection"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "scheduled",
                "inspecting",
                "report",
                "follow_up",
                "closed"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "establishment",
            "address"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Closed",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "closed"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "establishment",
            "address",
            "type",
            "score",
            "violations",
            "critical_violations",
            "result",
            "status"
          ],
          "required_fields": [
            "establishment",
            "address"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "establishment",
            "address",
            "type",
            "score",
            "violations",
            "critical_violations",
            "result",
            "status"
          ],
          "required_fields": [
            "establishment",
            "address"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/inspections/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "establishment"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "establishment",
            "address",
            "type",
            "score"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "establishment",
                "address",
                "type",
                "score",
                "violations",
                "critical_violations"
              ]
            }
          ]
        }
      }
    },
