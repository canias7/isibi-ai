            "value",
            "date",
            "status"
          ],
          "required_fields": [
            "property_address",
            "client"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/appraisals/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "property_address"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "property_address",
            "client",
            "type",
            "value"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "property_address",
                "client",
                "type",
                "value",
                "date",
                "status"
              ]
            }
          ]
        }
      }
