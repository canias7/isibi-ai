  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Class",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Total Students",
        "entity": "Student",
        "method": "count",
