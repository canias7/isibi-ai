      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Classs",
      "route": "/classes",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Class"
    },
    {
      "name": "Students",
      "route": "/students",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
