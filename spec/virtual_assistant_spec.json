{
  "_meta": {
    "app_name": "Virtual Assistant",
    "description": "Virtual Assistant management"
  },
  "entities": [
    {
      "name": "Client",
      "table": "clients",
      "description": "Client",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Enter name",
          "help_text": "Full name"
        },
        {
          "name": "email",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "validation": {
            "pattern": "^[^@]+@[^@]+\\.[^@]+$",
            "message": "Enter a valid email address"
          },
          "placeholder": "email@example.com",
          "help_text": "Primary email address"
        },
        {
          "name": "plan",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "5_hours",
            "10_hours",
            "20_hours",
            "unlimited"
          ],
          "badge_colors": {
            "5_hours": "pink",
            "10_hours": "blue",
            "20_hours": "green",
            "unlimited": "amber"
          }
        },
        {
          "name": "hours_used",
          "db_type": "NUMERIC(8,2) DEFAULT 0",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "phone",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "validation": {
            "pattern": "^\\+?[\\d\\s\\-\\(\\)]{7,20}$",
            "message": "Enter a valid phone number"
          },
          "placeholder": "+1 (555) 000-0000",
          "help_text": "Contact phone number"
        },
        {
          "name": "company",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Company name",
          "help_text": "Organization or company name"
        },
        {
          "name": "notes",
          "db_type": "TEXT",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "textarea",
          "display_component": "text",
          "placeholder": "Additional notes...",
          "help_text": "Internal notes (not visible to customers)"
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "email",
            "plan",
            "hours_used"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Clients yet",
            "subtext": "Add client",
            "action_label": "Add Client"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "name",
            "email",
            "phone",
            "company"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "email",
            "plan",
            "hours_used"
          ],
          "required_fields": [
            "name",
            "email"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "email",
            "plan",
            "hours_used"
          ],
          "required_fields": [
            "name",
            "email"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/clients/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "email",
            "plan",
            "hours_used"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "email",
                "plan",
                "hours_used"
              ]
            }
          ]
        }
      }
    },
    {
