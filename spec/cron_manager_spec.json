      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "schedule",
            "last_run",
            "next_run",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Jobs yet",
            "subtext": "Add job",
            "action_label": "Add Job"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "schedule",
            "command",
            "last_run",
            "next_run",
            "status"
          ],
          "required_fields": [
            "name",
            "schedule"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "schedule",
            "command",
            "last_run",
            "next_run",
            "status"
          ],
          "required_fields": [
            "name",
            "schedule"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/jobs/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "schedule",
            "last_run",
            "next_run"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "schedule",
                "last_run",
                "next_run",
                "status"
              ]
            }
          ]
        }
      }
    },
