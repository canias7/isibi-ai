{
  "_meta": {
    "app_name": "Ambulance Service",
    "description": "EMS dispatch"
  },
  "entities": [
    {
      "name": "Call",
      "table": "calls",
      "description": "Call",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "caller_name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "address",
          "db_type": "VARCHAR(500)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Street, City, State, ZIP",
          "help_text": "Full mailing address"
        },
        {
          "name": "priority",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "emergency",
            "urgent",
            "routine",
            "transfer"
          ],
          "badge_colors": {
            "emergency": "pink",
            "urgent": "blue",
            "routine": "green",
            "transfer": "amber"
          }
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "received",
            "dispatched",
            "en_route",
            "on_scene",
            "transporting",
            "completed"
          ],
          "badge_colors": {
            "received": "pink",
            "dispatched": "blue",
            "en_route": "green",
            "on_scene": "amber",
            "transporting": "purple",
            "completed": "red"
          }
        },
        {
          "name": "description",
          "db_type": "TEXT",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "textarea",
          "display_component": "text",
          "placeholder": "Enter description...",
          "help_text": "Brief description"
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "caller_name",
            "address",
            "priority",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Calls yet",
            "subtext": "Add call",
            "action_label": "Add Call"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "received",
                "dispatched",
                "en_route",
                "on_scene",
                "transporting",
                "completed"
              ]
            },
            {
              "field": "priority",
              "label": "Priority",
              "options": [
                "emergency",
                "urgent",
                "routine",
                "transfer"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "caller_name",
            "address",
            "description"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Completed",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "completed"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "caller_name",
            "address",
            "priority",
            "status"
          ],
          "required_fields": [
            "caller_name",
            "address"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "caller_name",
            "address",
            "priority",
            "status"
          ],
          "required_fields": [
            "caller_name",
            "address"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/calls/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "caller_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "caller_name",
            "address",
            "priority",
            "status"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "caller_name",
                "address",
                "priority",
                "status"
              ]
            }
          ]
        }
      }
    },
