  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Keys",
      "route": "/keys",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Key"
    },
    {
      "name": "Requests",
      "route": "/requests",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Request"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Key",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Total Requests",
        "entity": "Request",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Active Requests",
        "entity": "Request",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "pending"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Completed Requests",
        "entity": "Request",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "approved"
        },
        "icon": "CheckCircle",
        "color": "emerald"
      }
    ]
  },
  "design_system": {
    "theme": "light",
    "colors": {
      "primary": "#ec4899",
