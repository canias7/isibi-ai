{
  "_meta": {
    "app_name": "Countertop Shop",
    "description": "Countertop fabrication"
  },
  "entities": [
    {
      "name": "Job",
      "table": "jobs",
      "description": "Job",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "customer_name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "material",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "granite",
            "quartz",
            "marble",
            "quartzite",
            "soapstone",
            "butcher_block",
            "concrete",
            "laminate"
          ],
          "badge_colors": {
            "granite": "pink",
            "quartz": "blue",
            "marble": "green",
            "quartzite": "amber",
            "soapstone": "purple",
            "butcher_block": "red",
            "concrete": "slate",
            "laminate": "pink"
          }
        },
        {
          "name": "type",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "kitchen",
            "bathroom",
            "bar",
            "outdoor",
            "commercial"
          ],
          "badge_colors": {
            "kitchen": "pink",
            "bathroom": "blue",
            "bar": "green",
            "outdoor": "amber",
            "commercial": "purple"
          }
        },
