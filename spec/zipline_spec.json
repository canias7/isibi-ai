      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "date",
            "time",
            "guide_name",
            "participants",
            "type",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Tours yet",
            "subtext": "Add your first tour",
            "action_label": "Add Tour"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "date",
            "time",
            "guide_name",
            "participants",
            "type",
            "status"
          ],
          "required_fields": [
            "date",
            "time"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "date",
            "time",
            "guide_name",
            "participants",
            "type",
            "status"
          ],
          "required_fields": [
            "date",
            "time"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/tours/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "date"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "date",
            "time",
            "guide_name",
            "participants"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "date",
                "time",
                "guide_name",
                "participants",
                "type",
                "status"
              ]
            }
          ]
        }
      }
    },
