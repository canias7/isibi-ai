            "icon": "Box",
            "heading": "No Dogs yet",
            "subtext": "Create your first dog",
            "action_label": "Add Dog"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "breed",
            "size",
            "owner_name",
            "owner_phone",
            "temperament",
            "vaccinations_current"
          ],
          "required_fields": [
            "name",
            "breed"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "breed",
            "size",
            "owner_name",
            "owner_phone",
            "temperament",
            "vaccinations_current"
          ],
          "required_fields": [
            "name",
            "breed"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/dogs/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "breed",
            "size",
            "owner_name"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "breed",
                "size",
                "owner_name",
                "owner_phone"
              ]
            }
          ]
        }
