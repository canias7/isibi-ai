            "beginner",
            "intermediate",
            "advanced",
            "elite"
          ],
          "badge_colors": {
            "beginner": "pink",
            "intermediate": "blue",
            "advanced": "green",
            "elite": "amber"
          }
        },
        {
          "name": "status",
