{
  "_meta": {
    "app_name": "Print Shop",
    "description": "Print and copy shop"
  },
  "entities": [
    {
      "name": "Order",
      "table": "orders",
      "description": "Print order",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "customer_id",
          "db_type": "UUID",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "relation_picker",
          "display_component": "relation_link",
          "foreign_key": {
            "table": "customers",
            "column": "id",
            "display_column": "name"
          }
        },
        {
          "name": "customer_name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "description",
          "db_type": "TEXT",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Enter description...",
          "help_text": "Brief description"
        },
        {
          "name": "type",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "business_cards",
            "flyers",
            "banners",
            "posters",
            "booklets",
            "stickers",
            "custom"
          ],
          "badge_colors": {
            "business_cards": "blue",
            "flyers": "green",
            "banners": "amber",
            "posters": "purple",
            "booklets": "pink",
            "stickers": "blue",
            "custom": "slate"
          }
        },
        {
          "name": "quantity",
          "db_type": "INTEGER",
          "ts_type": "number",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text",
          "validation": {
            "min": 0,
            "message": "Quantity must be a positive number"
          },
          "placeholder": "1",
          "help_text": "Number of units"
        },
        {
          "name": "price",
          "db_type": "NUMERIC(10,2)",
          "ts_type": "number",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text",
          "validation": {
            "min": 0,
            "message": "Price must be a positive number"
          },
          "placeholder": "0.00",
          "help_text": "Price in USD"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "received",
            "designing",
            "printing",
            "finishing",
            "ready",
            "picked_up"
          ],
          "badge_colors": {
            "received": "slate",
            "designing": "blue",
            "printing": "amber",
            "finishing": "purple",
            "ready": "green",
            "picked_up": "slate"
          }
        },
        {
          "name": "total",
          "db_type": "NUMERIC(10,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text",
          "computed": {
            "formula": "quantity * price",
            "dependencies": [
              "quantity",
              "price"
            ]
          },
          "placeholder": "0.00",
          "help_text": "Total amount in USD"
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "customer_name",
            "description",
            "type",
            "quantity",
            "price",
            "status",
            "total",
            "customer_id"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Orders yet",
            "subtext": "Create your first order",
            "action_label": "Add Order"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "received",
                "designing",
                "printing",
                "finishing",
                "ready",
                "picked_up"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "customer_name",
            "description"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "description",
            "type",
            "quantity",
            "price",
            "status",
            "total",
            "customer_id"
          ],
          "required_fields": [
            "customer_name",
            "description"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "description",
            "type",
            "quantity",
            "price",
            "status",
            "total",
            "customer_id"
          ],
          "required_fields": [
            "customer_name",
            "description"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/orders/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "customer_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "customer_name",
            "description",
            "type",
            "quantity"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "customer_name",
                "description",
                "type",
                "quantity",
                "price",
                "status",
                "total",
                "customer_id"
              ]
            }
          ]
        }
      }
    },
