      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "customer_name",
            "description",
            "type",
            "quantity",
            "price",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Orders yet",
            "subtext": "Create your first order",
            "action_label": "Add Order"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "description",
            "type",
            "quantity",
            "price",
            "status"
          ],
          "required_fields": [
            "customer_name",
            "description"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "description",
            "type",
            "quantity",
            "price",
            "status"
          ],
          "required_fields": [
            "customer_name",
            "description"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/orders/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "customer_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "customer_name",
            "description",
            "type",
            "quantity"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "customer_name",
                "description",
                "type",
                "quantity",
                "price",
                "status"
              ]
            }
          ]
        }
      }
    },
