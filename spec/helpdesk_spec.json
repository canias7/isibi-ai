{
  "_meta": {
    "app_name": "Helpdesk",
    "description": "Customer support helpdesk"
  },
  "entities": [
    {
      "name": "Ticket",
      "table": "tickets",
      "description": "Support ticket",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "subject",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "requester_email",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "description",
          "db_type": "TEXT",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": false,
          "show_in_form": true,
          "input_component": "textarea",
          "display_component": "text"
        },
        {
          "name": "priority",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "low",
            "medium",
            "high",
            "urgent"
          ],
          "badge_colors": {
            "low": "pink",
            "medium": "blue",
            "high": "green",
            "urgent": "amber"
          }
        },
        {
          "name": "category",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "billing",
            "technical",
            "account",
            "feature_request",
            "bug"
          ],
          "badge_colors": {
            "billing": "pink",
            "technical": "blue",
            "account": "green",
            "feature_request": "amber",
            "bug": "purple"
          }
        },
        {
          "name": "assigned_to",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": false,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "open",
            "pending",
            "in_progress",
            "resolved",
            "closed"
          ],
          "badge_colors": {
            "open": "pink",
            "pending": "blue",
            "in_progress": "green",
            "resolved": "amber",
            "closed": "purple"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "subject",
            "requester_email",
            "priority",
            "category",
            "assigned_to"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Tickets yet",
            "subtext": "Create your first ticket",
            "action_label": "Add Ticket"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "subject",
            "requester_email",
            "description",
            "priority",
            "category",
            "assigned_to",
            "status"
          ],
          "required_fields": [
            "subject",
            "requester_email"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "subject",
            "requester_email",
            "description",
            "priority",
            "category",
            "assigned_to",
            "status"
          ],
          "required_fields": [
            "subject",
            "requester_email"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/tickets/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "subject"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "subject",
            "requester_email",
            "priority",
            "category"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "subject",
                "requester_email",
                "priority",
                "category",
                "assigned_to"
              ]
            }
          ]
        }
      }
    },
