      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Bots",
      "route": "/bots",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Bot"
    },
    {
      "name": "Intents",
      "route": "/intents",
      "component": "EntityListPage",
