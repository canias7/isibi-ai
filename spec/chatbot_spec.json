{
  "_meta": {
    "app_name": "Chatbot Builder",
    "description": "Chatbot Builder management"
  },
  "entities": [
    {
      "name": "Bot",
      "table": "bots",
      "description": "Bot",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "platform",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "web",
            "slack",
            "discord",
            "telegram",
            "whatsapp",
            "messenger"
          ],
          "badge_colors": {
            "web": "pink",
            "slack": "blue",
            "discord": "green",
            "telegram": "amber",
            "whatsapp": "purple",
            "messenger": "red"
          }
        },
        {
          "name": "messages_handled",
          "db_type": "INTEGER DEFAULT 0",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "draft",
            "training",
            "deployed",
            "paused"
          ],
          "badge_colors": {
            "draft": "pink",
            "training": "blue",
            "deployed": "green",
            "paused": "amber"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "platform",
            "messages_handled",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Bots yet",
            "subtext": "Add bot",
            "action_label": "Add Bot"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "platform",
            "messages_handled",
            "status"
          ],
          "required_fields": [
            "name",
            "platform"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "platform",
            "messages_handled",
            "status"
          ],
          "required_fields": [
            "name",
            "platform"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/bots/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "platform",
            "messages_handled",
            "status"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "platform",
                "messages_handled",
                "status"
              ]
            }
          ]
        }
      }
    },
