          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "available",
            "reserved",
            "sold",
            "on_loan",
            "exhibition"
          ],
          "badge_colors": {
            "available": "green",
            "reserved": "amber",
            "sold": "slate",
            "on_loan": "blue",
            "exhibition": "purple"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "title",
            "artist_name",
            "medium",
            "price",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Artworks yet",
            "subtext": "Create your first artwork",
            "action_label": "Add Artwork"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "available",
                "reserved",
                "sold",
                "on_loan",
                "exhibition"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "title",
            "artist_name"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "artist_name",
            "medium",
            "price",
            "status"
          ],
          "required_fields": [
            "title",
            "artist_name"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "artist_name",
            "medium",
            "price",
            "status"
          ],
          "required_fields": [
            "title",
            "artist_name"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/artworks/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "title"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "title",
            "artist_name",
            "medium",
            "price"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "title",
                "artist_name",
                "medium",
                "price",
                "status"
              ]
            }
          ]
        }
      }
    },
