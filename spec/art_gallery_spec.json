{
  "_meta": {
    "app_name": "Art Gallery",
    "description": "Art gallery management"
  },
  "entities": [
    {
      "name": "Artwork",
      "table": "artworks",
      "description": "Art piece",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "title",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Enter title",
          "help_text": "Short descriptive title"
        },
        {
          "name": "artist_name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "medium",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "painting",
            "sculpture",
            "photography",
            "print",
            "digital",
            "mixed_media",
            "installation"
          ],
          "badge_colors": {
            "painting": "blue",
            "sculpture": "amber",
            "photography": "purple",
            "print": "green",
            "digital": "pink",
            "mixed_media": "slate",
            "installation": "purple"
          }
        },
        {
          "name": "price",
          "db_type": "NUMERIC(12,2)",
          "ts_type": "number",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
