          "header": {
            "title_fields": [
              "client_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "client_name",
            "type",
            "investigator_name",
            "retainer"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "client_name",
                "type",
                "investigator_name",
                "retainer",
                "status"
              ]
            }
          ]
        }
      }
