{
  "_meta": {
    "app_name": "Voice Over",
    "description": "Voice acting studio"
  },
  "entities": [
    {
      "name": "Project",
      "table": "projects",
      "description": "VO project",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "title",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Enter title",
          "help_text": "Short descriptive title"
        },
        {
          "name": "client_name",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "type",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "commercial",
            "narration",
            "audiobook",
            "elearning",
            "gaming",
            "ivr",
            "podcast"
          ],
          "badge_colors": {
            "commercial": "pink",
            "narration": "blue",
            "audiobook": "green",
            "elearning": "amber",
            "gaming": "purple",
            "ivr": "red",
            "podcast": "slate"
          }
        },
        {
          "name": "word_count",
          "db_type": "INTEGER",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "price",
          "db_type": "NUMERIC(10,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text",
          "validation": {
            "min": 0,
            "message": "Price must be a positive number"
          },
          "placeholder": "0.00",
          "help_text": "Price in USD"
        },
        {
          "name": "deadline",
          "db_type": "DATE",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "date_input",
          "display_component": "date"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": false,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "audition",
            "booked",
            "recording",
            "editing",
            "delivered"
          ],
          "badge_colors": {
            "audition": "pink",
            "booked": "blue",
            "recording": "green",
            "editing": "amber",
            "delivered": "purple"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "title",
            "client_name",
            "type",
            "word_count",
            "price",
            "deadline"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Projects yet",
            "subtext": "Create your first project",
            "action_label": "Add Project"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            },
            {
              "name": "Calendar",
              "layout": "calendar",
              "date_field": "deadline"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "audition",
                "booked",
                "recording",
                "editing",
                "delivered"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "title",
            "client_name"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Delivered",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "delivered"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "client_name",
            "type",
            "word_count",
            "price",
            "deadline",
            "status"
          ],
          "required_fields": [
            "title",
            "client_name"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "client_name",
            "type",
            "word_count",
            "price",
            "deadline",
            "status"
          ],
          "required_fields": [
            "title",
            "client_name"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/projects/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "title"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "title",
            "client_name",
            "type",
            "word_count"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "title",
                "client_name",
                "type",
                "word_count",
                "price",
                "deadline"
              ]
            }
          ]
        }
      }
    },
    {
      "name": "Talent",
      "table": "talent",
      "description": "Voice talent",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Enter name",
          "help_text": "Full name"
        },
        {
          "name": "email",
          "db_type": "VARCHAR(255)",
