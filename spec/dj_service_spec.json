      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "client_name",
            "type",
            "date",
            "venue",
            "hours",
            "price"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Events yet",
            "subtext": "Add event",
            "action_label": "Add Event"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client_name",
            "type",
            "date",
            "venue",
            "hours",
            "price",
            "status"
          ],
          "required_fields": [
            "client_name",
            "type"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client_name",
            "type",
            "date",
            "venue",
            "hours",
            "price",
            "status"
          ],
          "required_fields": [
            "client_name",
            "type"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/events/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "client_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "client_name",
            "type",
            "date",
            "venue"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "client_name",
                "type",
                "date",
                "venue",
                "hours",
                "price"
              ]
            }
          ]
        }
      }
    },
