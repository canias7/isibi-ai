{
  "_meta": {
    "app_name": "Parking Lot",
    "description": "Surface parking lot"
  },
  "entities": [
    {
      "name": "Space",
      "table": "spaces",
      "description": "Parking space",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "number",
          "db_type": "VARCHAR(10) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "type",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "regular",
            "handicap",
            "ev",
            "reserved",
            "motorcycle"
          ],
          "badge_colors": {
            "regular": "pink",
            "handicap": "blue",
            "ev": "green",
            "reserved": "amber",
            "motorcycle": "purple"
          }
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "available",
            "occupied",
            "reserved"
          ],
          "badge_colors": {
            "available": "pink",
            "occupied": "blue",
            "reserved": "green"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "number",
            "type",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Spaces yet",
            "subtext": "Create your first space",
            "action_label": "Add Space"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "number",
            "type",
            "status"
          ],
          "required_fields": [
            "number",
            "type"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "number",
            "type",
            "status"
          ],
          "required_fields": [
            "number",
            "type"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/spaces/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "number"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "number",
            "type",
            "status"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "number",
                "type",
                "status"
              ]
            }
          ]
        }
      }
    },
