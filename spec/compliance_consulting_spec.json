  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Clients",
      "route": "/clients",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Client"
    },
    {
      "name": "Audits",
      "route": "/audits",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Audit"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Client",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Total Audits",
        "entity": "Audit",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Active Audits",
        "entity": "Audit",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "scheduled"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Completed Audits",
        "entity": "Audit",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "closed"
        },
        "icon": "CheckCircle",
        "color": "emerald"
      }
    ]
  },
