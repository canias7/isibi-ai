  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Macaron",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Total Price Each",
        "entity": "Macaron",
        "method": "sum",
        "field": "price_each",
        "icon": "DollarSign",
        "color": "amber"
      },
      {
        "label": "Total Orders",
        "entity": "Order",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Total Total",
        "entity": "Order",
        "method": "sum",
        "field": "total",
        "icon": "DollarSign",
        "color": "amber"
      }
    ]
