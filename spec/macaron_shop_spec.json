          "type": "SlideOverForm",
          "field_order": [
            "flavor",
            "color",
            "price_each",
            "available"
          ],
          "required_fields": [
            "flavor",
            "color"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "flavor",
            "color",
            "price_each",
            "available"
          ],
          "required_fields": [
            "flavor",
            "color"
          ],
          "prefilled": true
        },
