        "list_view": {
          "layout": "table",
          "columns": [
            "flavor",
            "color",
            "price_each",
            "available"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Macarons yet",
            "subtext": "Add macaron",
            "action_label": "Add Macaron"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
