      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "serial",
            "type",
            "owner",
            "last_cal",
            "next_due"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Instruments yet",
            "subtext": "Add instrument",
            "action_label": "Add Instrument"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "serial",
            "type",
            "owner",
            "last_cal",
            "next_due",
            "status"
          ],
          "required_fields": [
            "name",
            "serial"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "serial",
            "type",
            "owner",
            "last_cal",
            "next_due",
            "status"
          ],
          "required_fields": [
            "name",
            "serial"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/instruments/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "serial",
            "type",
            "owner"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "serial",
                "type",
                "owner",
                "last_cal",
                "next_due"
              ]
            }
          ]
        }
      }
    },
