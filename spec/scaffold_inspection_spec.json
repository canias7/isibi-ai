{
  "_meta": {
    "app_name": "Scaffold Inspection",
    "description": "Scaffold Inspection management"
  },
  "entities": [
    {
      "name": "Inspection",
      "table": "inspections",
      "description": "Inspection",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "site",
          "db_type": "VARCHAR(500) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "contractor",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "type",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "erection",
            "daily",
            "weekly",
            "post_incident",
            "modification"
          ],
          "badge_colors": {
            "erection": "pink",
            "daily": "blue",
            "weekly": "green",
            "post_incident": "amber",
            "modification": "purple"
          }
        },
        {
          "name": "inspector",
