      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "site",
            "contractor",
            "type",
            "inspector",
            "result",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Inspections yet",
            "subtext": "Add inspection",
            "action_label": "Add Inspection"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "scheduled",
                "completed",
                "follow_up"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "site",
            "contractor",
            "inspector"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Completed",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "completed"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "site",
            "contractor",
            "type",
            "inspector",
            "result",
            "status"
          ],
          "required_fields": [
            "site",
            "contractor"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "site",
            "contractor",
            "type",
            "inspector",
            "result",
            "status"
          ],
          "required_fields": [
            "site",
            "contractor"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/inspections/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "site"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "site",
            "contractor",
            "type",
            "inspector"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "site",
                "contractor",
                "type",
                "inspector",
                "result",
                "status"
              ]
            }
          ]
        }
      }
    },
