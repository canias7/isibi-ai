  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Inspections",
      "route": "/inspections",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Inspection"
    },
    {
      "name": "Scaffolds",
      "route": "/scaffolds",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Scaffold"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Inspection",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Inspections",
        "entity": "Inspection",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "scheduled"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Completed Inspections",
        "entity": "Inspection",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "completed"
        },
        "icon": "CheckCircle",
        "color": "emerald"
      },
      {
        "label": "Total Scaffolds",
        "entity": "Scaffold",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      }
    ]
  },
