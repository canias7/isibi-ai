  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Events",
      "route": "/events",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Event"
    },
    {
      "name": "Tickets",
      "route": "/tickets",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Ticket"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Event",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Events",
        "entity": "Event",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "scheduled"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Total Price Pp",
        "entity": "Event",
        "method": "sum",
        "field": "price_pp",
        "icon": "DollarSign",
        "color": "amber"
      },
      {
        "label": "Total Tickets",
        "entity": "Ticket",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      }
    ]
