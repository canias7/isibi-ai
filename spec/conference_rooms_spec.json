  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Room",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      }
    ]
  },
  "design_system": {
    "theme": "light",
    "colors": {
      "primary": "#ec4899",
