            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "breed",
            "age",
            "personality",
            "adoptable",
            "status"
          ],
          "required_fields": [
            "name",
            "breed"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "breed",
            "age",
            "personality",
            "adoptable",
            "status"
          ],
          "required_fields": [
            "name",
            "breed"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/cats/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "breed",
            "age",
            "adoptable"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "breed",
                "age",
                "adoptable",
                "status"
              ]
            }
          ]
        }
      }
    },
