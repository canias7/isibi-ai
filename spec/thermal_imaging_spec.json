{
  "_meta": {
    "app_name": "Thermal Imaging",
    "description": "Thermal Imaging management"
  },
  "entities": [
    {
      "name": "Survey",
      "table": "surveys",
      "description": "Survey",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "client",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "address",
          "db_type": "VARCHAR(500)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Street, City, State, ZIP",
          "help_text": "Full mailing address"
        },
        {
          "name": "type",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "electrical",
            "mechanical",
            "building",
            "moisture",
            "roof",
            "plumbing"
          ],
          "badge_colors": {
            "electrical": "pink",
            "mechanical": "blue",
            "building": "green",
            "moisture": "amber",
            "roof": "purple",
            "plumbing": "red"
          }
        },
        {
          "name": "anomalies_found",
          "db_type": "INTEGER DEFAULT 0",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "scheduled",
            "scanning",
            "analyzing",
            "reported"
          ],
          "badge_colors": {
            "scheduled": "pink",
            "scanning": "blue",
            "analyzing": "green",
            "reported": "amber"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "client",
            "address",
            "type",
            "anomalies_found",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Surveys yet",
            "subtext": "Add survey",
            "action_label": "Add Survey"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "scheduled",
                "scanning",
                "analyzing",
                "reported"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "client",
            "address"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client",
            "address",
            "type",
            "anomalies_found",
            "status"
          ],
          "required_fields": [
            "client",
            "address"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client",
            "address",
            "type",
            "anomalies_found",
            "status"
          ],
          "required_fields": [
            "client",
            "address"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/surveys/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "client"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "client",
            "address",
            "type",
            "anomalies_found"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "client",
                "address",
                "type",
                "anomalies_found",
                "status"
              ]
            }
          ]
        }
      }
    },
