            "name",
            "repo",
            "branch",
            "trigger",
            "duration_sec",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Pipelines yet",
            "subtext": "Add pipeline",
            "action_label": "Add Pipeline"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "repo",
            "branch",
            "trigger",
            "duration_sec",
            "status"
          ],
          "required_fields": [
            "name",
            "repo"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "repo",
            "branch",
            "trigger",
            "duration_sec",
            "status"
          ],
          "required_fields": [
            "name",
            "repo"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/pipelines/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "repo",
            "branch",
            "trigger"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "repo",
                "branch",
                "trigger",
                "duration_sec",
                "status"
              ]
            }
          ]
        }
      }
    },
