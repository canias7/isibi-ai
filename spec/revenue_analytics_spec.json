          "name": "actual_revenue",
          "db_type": "NUMERIC(15,2)",
          "ts_type": "number",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "currency",
          "placeholder": "0.00",
          "help_text": "Enter actual revenue"
        },
        {
          "name": "variance",
          "db_type": "NUMERIC(15,2) NOT NULL",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "number_input",
          "display_component": "currency",
          "computed": "actual_revenue - predicted_revenue",
          "validation": {
            "min": 0
          },
          "placeholder": "0.00",
          "help_text": "Enter variance"
        },
        {
          "name": "accuracy_pct",
          "db_type": "NUMERIC(5,2)",
          "ts_type": "number",
          "nullable": true,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "number_input",
          "display_component": "percentage",
          "computed": "1 - ABS(variance / predicted_revenue) * 100"
        },
