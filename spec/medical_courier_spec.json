{
  "_meta": {
    "app_name": "Medical Courier",
    "description": "Medical Courier management"
  },
  "entities": [
    {
      "name": "Delivery",
      "table": "deliveries",
      "description": "Delivery",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "facility",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "type",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "specimen",
            "organ",
            "blood",
            "medication",
            "equipment",
            "records"
          ],
          "badge_colors": {
            "specimen": "pink",
            "organ": "blue",
            "blood": "green",
            "medication": "amber",
            "equipment": "purple",
            "records": "red"
          }
        },
        {
          "name": "priority",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "routine",
            "stat",
            "critical"
          ],
          "badge_colors": {
            "routine": "pink",
            "stat": "blue",
            "critical": "green"
          }
        },
        {
          "name": "pickup",
          "db_type": "VARCHAR(500)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "destination",
          "db_type": "VARCHAR(500)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "courier",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": false,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "dispatched",
            "picked_up",
            "in_transit",
            "delivered"
          ],
          "badge_colors": {
            "dispatched": "pink",
            "picked_up": "blue",
            "in_transit": "green",
            "delivered": "amber"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "facility",
            "type",
            "priority",
            "pickup",
            "destination",
            "courier"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Deliverys yet",
            "subtext": "Add delivery",
            "action_label": "Add Delivery"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "dispatched",
                "picked_up",
                "in_transit",
                "delivered"
              ]
            },
            {
              "field": "priority",
              "label": "Priority",
              "options": [
                "routine",
                "stat",
                "critical"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "facility",
            "pickup",
            "destination",
            "courier"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Delivered",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "delivered"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "facility",
            "type",
            "priority",
            "pickup",
            "destination",
            "courier",
            "status"
          ],
          "required_fields": [
            "facility",
            "type"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "facility",
            "type",
            "priority",
            "pickup",
            "destination",
            "courier",
            "status"
          ],
          "required_fields": [
            "facility",
            "type"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/deliveries/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "facility"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "facility",
            "type",
            "priority",
            "pickup"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "facility",
                "type",
                "priority",
                "pickup",
                "destination",
                "courier"
              ]
            }
          ]
        }
      }
    },
    {
      "name": "Courier",
