        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "client",
            "platform",
            "budget",
            "spend",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Campaigns yet",
            "subtext": "Add campaign",
            "action_label": "Add Campaign"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client",
            "platform",
            "budget",
            "spend",
            "status"
          ],
          "required_fields": [
            "client",
            "platform"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client",
            "platform",
            "budget",
            "spend",
            "status"
          ],
          "required_fields": [
            "client",
            "platform"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/campaigns/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "client"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "client",
            "platform",
            "budget",
            "spend"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "client",
                "platform",
                "budget",
                "spend",
                "status"
              ]
            }
          ]
        }
      }
    },
