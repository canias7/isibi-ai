            "name",
            "dob",
            "parent_name",
            "parent_phone",
            "classroom",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Childs yet",
            "subtext": "Add child",
            "action_label": "Add Child"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "dob",
            "parent_name",
            "parent_phone",
            "classroom",
            "status"
          ],
          "required_fields": [
            "name",
            "dob"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "dob",
            "parent_name",
            "parent_phone",
            "classroom",
            "status"
          ],
          "required_fields": [
            "name",
            "dob"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/children/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "dob",
            "parent_name",
            "parent_phone"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "dob",
                "parent_name",
                "parent_phone",
                "classroom",
                "status"
              ]
            }
          ]
        }
      }
    },
