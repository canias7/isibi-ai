      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "title",
            "headliner",
            "date",
            "time",
            "tickets_available",
            "price"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Shows yet",
            "subtext": "Add your first show",
            "action_label": "Add Show"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            },
            {
              "name": "Calendar",
              "layout": "calendar",
              "date_field": "date"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "on_sale",
                "sold_out",
                "completed",
                "cancelled"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "title",
            "headliner"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Completed",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "completed"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "headliner",
            "date",
            "time",
            "tickets_available",
            "price",
            "status"
          ],
          "required_fields": [
            "title",
            "headliner"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "headliner",
            "date",
            "time",
            "tickets_available",
            "price",
            "status"
          ],
          "required_fields": [
            "title",
            "headliner"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/shows/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "title"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "title",
            "headliner",
            "date",
            "time"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "title",
                "headliner",
                "date",
                "time",
                "tickets_available",
                "price"
              ]
            }
          ]
        }
      }
    },
