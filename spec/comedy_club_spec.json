{
  "_meta": {
    "app_name": "Comedy Club",
    "description": "Stand-up comedy"
  },
  "entities": [
    {
      "name": "Show",
      "table": "shows",
      "description": "Show entity",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "title",
          "db_type": "VARCHAR(255) NOT NULL",
