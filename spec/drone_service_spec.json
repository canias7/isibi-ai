      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "client_name",
            "location",
            "type",
            "date",
            "price",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Jobs yet",
            "subtext": "Create your first job",
            "action_label": "Add Job"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client_name",
            "location",
            "type",
            "date",
            "price",
            "status"
          ],
          "required_fields": [
            "client_name",
            "location"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client_name",
            "location",
            "type",
            "date",
            "price",
            "status"
          ],
          "required_fields": [
            "client_name",
            "location"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/jobs/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "client_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "client_name",
            "location",
            "type",
            "date"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "client_name",
                "location",
                "type",
                "date",
                "price",
                "status"
              ]
            }
          ]
        }
      }
