  "dashboard": {
    "stat_cards": [
      {
        "label": "Total Jobs",
        "entity": "Job",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Completed Jobs",
        "entity": "Job",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "completed"
        },
        "icon": "CheckCircle",
        "color": "emerald"
      },
      {
        "label": "Total Price",
        "entity": "Job",
        "method": "sum",
        "field": "price",
        "icon": "DollarSign",
        "color": "amber"
      },
      {
        "label": "Total Customers",
