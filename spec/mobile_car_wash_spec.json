          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "scheduled",
            "en_route",
            "washing",
            "completed",
            "cancelled"
          ],
          "badge_colors": {
            "scheduled": "blue",
            "en_route": "purple",
            "washing": "amber",
            "completed": "green",
            "cancelled": "red"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "customer_name",
            "phone",
            "address",
            "vehicle_info",
            "service",
            "price",
            "customer_id"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Appointments yet",
            "subtext": "Create your first appointment",
            "action_label": "Add Appointment"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            },
            {
              "name": "Calendar",
              "layout": "calendar",
              "date_field": "date"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "scheduled",
                "en_route",
                "washing",
                "completed",
                "cancelled"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "customer_name",
            "phone",
            "address",
            "vehicle_info"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Completed",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "completed"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "phone",
            "address",
            "vehicle_info",
            "service",
            "price",
            "date",
            "time",
            "status",
            "customer_id"
          ],
          "required_fields": [
            "customer_name",
            "phone"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "phone",
            "address",
            "vehicle_info",
            "service",
            "price",
            "date",
            "time",
            "status",
            "customer_id"
          ],
          "required_fields": [
            "customer_name",
            "phone"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/appointments/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "customer_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "customer_name",
            "phone",
            "address",
            "vehicle_info"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "customer_name",
                "phone",
                "address",
                "vehicle_info",
                "service",
                "price",
                "date",
                "time",
                "status",
                "customer_id"
              ]
            }
          ]
        }
      }
    },
