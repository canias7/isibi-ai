          "header": {
            "title_fields": [
              "building"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "building",
            "address",
            "elevator_id",
            "type"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "building",
                "address",
                "elevator_id",
                "type",
                "result",
                "status"
              ]
            }
          ]
        }
