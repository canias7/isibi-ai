        "list_view": {
          "layout": "table",
          "columns": [
            "building",
            "address",
            "type",
            "violations",
            "result",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Inspections yet",
            "subtext": "Add inspection",
            "action_label": "Add Inspection"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "building",
            "address",
            "type",
            "violations",
            "result",
            "status"
          ],
          "required_fields": [
            "building",
            "address"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "building",
            "address",
            "type",
            "violations",
            "result",
            "status"
          ],
          "required_fields": [
            "building",
            "address"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/inspections/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "building"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "building",
            "address",
            "type",
            "violations"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "building",
                "address",
                "type",
                "violations",
                "result",
                "status"
              ]
            }
          ]
        }
      }
    },
