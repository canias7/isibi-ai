      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "customer_name",
            "address",
            "type",
            "rooms",
            "estimated_cost",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Projects yet",
            "subtext": "Create your first project",
            "action_label": "Add Project"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "address",
            "type",
            "rooms",
            "estimated_cost",
            "status"
          ],
          "required_fields": [
            "customer_name",
            "address"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "address",
            "type",
            "rooms",
            "estimated_cost",
            "status"
          ],
          "required_fields": [
            "customer_name",
            "address"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/projects/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "customer_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "customer_name",
            "address",
            "type",
            "rooms"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "customer_name",
                "address",
                "type",
                "rooms",
                "estimated_cost",
                "status"
              ]
            }
          ]
        }
      }
    },
