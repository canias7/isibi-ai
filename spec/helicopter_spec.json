  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Flights",
      "route": "/flights",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Flight"
    },
    {
      "name": "Aircrafts",
      "route": "/aircraft",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Aircraft"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Flight",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Flights",
        "entity": "Flight",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "booked"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Total Price",
        "entity": "Flight",
        "method": "sum",
        "field": "price",
        "icon": "DollarSign",
        "color": "amber"
      },
      {
        "label": "Total Aircrafts",
        "entity": "Aircraft",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      }
    ]
  },
