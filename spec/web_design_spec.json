        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "client",
            "type",
            "pages",
            "budget",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Projects yet",
            "subtext": "Add project",
            "action_label": "Add Project"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client",
            "type",
            "pages",
            "budget",
            "status"
          ],
          "required_fields": [
            "client",
            "type"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client",
            "type",
            "pages",
            "budget",
            "status"
          ],
          "required_fields": [
            "client",
            "type"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/projects/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "client"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "client",
            "type",
            "pages",
            "budget"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "client",
                "type",
                "pages",
                "budget",
                "status"
              ]
            }
          ]
        }
      }
    },
