        {
          "name": "budget",
          "db_type": "NUMERIC(10,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
