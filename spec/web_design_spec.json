            "landing_page",
            "corporate",
            "ecommerce",
            "portfolio",
            "blog",
            "saas"
          ],
          "badge_colors": {
            "landing_page": "pink",
            "corporate": "blue",
            "ecommerce": "green",
            "portfolio": "amber",
            "blog": "purple",
            "saas": "red"
          }
        },
        {
          "name": "pages",
          "db_type": "INTEGER",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
