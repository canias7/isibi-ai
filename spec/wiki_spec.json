          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "page_title",
            "author_name"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Comments yet",
            "subtext": "Create your first comment",
            "action_label": "Add Comment"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "page_title",
            "author_name",
            "description"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "page_title",
            "author_name",
            "content"
          ],
          "required_fields": [
            "page_title",
            "author_name"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "page_title",
            "author_name",
            "content"
          ],
          "required_fields": [
            "page_title",
            "author_name"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/comments/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
