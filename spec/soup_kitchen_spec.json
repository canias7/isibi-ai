        {
          "name": "servings_served",
          "db_type": "INTEGER DEFAULT 0",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "date",
            "servings_planned",
            "servings_served"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Meals yet",
            "subtext": "Add meal",
            "action_label": "Add Meal"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "date",
            "menu",
            "servings_planned",
            "servings_served"
          ],
          "required_fields": [
            "date",
            "menu"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "date",
            "menu",
            "servings_planned",
            "servings_served"
          ],
          "required_fields": [
            "date",
            "menu"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/meals/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "date"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "date",
            "servings_planned",
            "servings_served"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "date",
                "servings_planned",
                "servings_served"
              ]
            }
          ]
        }
      }
    },
