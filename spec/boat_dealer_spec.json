            "powerboat",
            "sailboat",
            "pontoon",
            "fishing",
            "jet_ski",
            "yacht"
          ],
          "badge_colors": {
            "powerboat": "pink",
            "sailboat": "blue",
            "pontoon": "green",
            "fishing": "amber",
            "jet_ski": "purple",
            "yacht": "red"
          }
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "available",
            "reserved",
            "sold",
            "consignment"
          ],
          "badge_colors": {
            "available": "pink",
            "reserved": "blue",
            "sold": "green",
            "consignment": "amber"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "make",
            "model",
            "year",
            "price",
            "type",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Boats yet",
            "subtext": "Add your first boat",
            "action_label": "Add Boat"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "make",
            "model",
            "year",
            "price",
            "type",
            "status"
          ],
          "required_fields": [
            "make",
            "model"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "make",
            "model",
            "year",
            "price",
            "type",
            "status"
          ],
          "required_fields": [
            "make",
            "model"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/boats/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "make"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "make",
            "model",
            "year",
            "price"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "make",
                "model",
                "year",
                "price",
                "type",
                "status"
              ]
            }
          ]
        }
      }
    },
