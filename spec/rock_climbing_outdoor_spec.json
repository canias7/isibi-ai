        "list_view": {
          "layout": "table",
          "columns": [
            "destination",
            "date",
            "type",
            "difficulty",
            "leader",
            "spots"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Trips yet",
            "subtext": "Add trip",
            "action_label": "Add Trip"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "destination",
            "date",
            "type",
            "difficulty",
            "leader",
            "spots",
            "status"
          ],
          "required_fields": [
            "destination",
            "date"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "destination",
            "date",
            "type",
            "difficulty",
            "leader",
            "spots",
            "status"
          ],
          "required_fields": [
            "destination",
            "date"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/trips/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "destination"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "destination",
            "date",
            "type",
            "difficulty"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "destination",
                "date",
                "type",
                "difficulty",
                "leader",
                "spots"
              ]
            }
          ]
        }
      }
    },
