            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "title",
            "rating"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "genre",
            "rating",
            "duration_min",
            "status"
          ],
          "required_fields": [
            "title",
            "genre"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "genre",
            "rating",
            "duration_min",
            "status"
          ],
          "required_fields": [
            "title",
            "genre"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/movies/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "title"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "title",
            "genre",
            "rating",
            "duration_min"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "title",
                "genre",
                "rating",
                "duration_min",
                "status"
              ]
            }
          ]
        }
      }
    },
