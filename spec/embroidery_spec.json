            "icon": "Box",
            "heading": "No Orders yet",
            "subtext": "Add order",
            "action_label": "Add Order"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "type",
            "design",
            "quantity",
            "price",
            "status"
          ],
          "required_fields": [
            "customer_name",
            "type"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "type",
            "design",
            "quantity",
            "price",
            "status"
          ],
          "required_fields": [
            "customer_name",
            "type"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/orders/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "customer_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "customer_name",
            "type",
            "quantity",
            "price"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "customer_name",
                "type",
                "quantity",
                "price",
                "status"
              ]
            }
          ]
        }
      }
    },
