        "list_view": {
          "layout": "table",
          "columns": [
            "title",
            "publisher",
            "issue_number",
            "price",
            "stock",
            "condition"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Comics yet",
            "subtext": "Create your first comic",
            "action_label": "Add Comic"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "publisher",
            "issue_number",
            "price",
            "stock",
            "condition"
          ],
          "required_fields": [
            "title",
            "publisher"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "publisher",
            "issue_number",
            "price",
            "stock",
            "condition"
          ],
          "required_fields": [
            "title",
            "publisher"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/comics/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "title"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "title",
            "publisher",
            "issue_number",
            "price"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "title",
                "publisher",
                "issue_number",
                "price",
                "stock",
                "condition"
              ]
            }
          ]
        }
      }
    },
