            "icon": "Box",
            "heading": "No Clients yet",
            "subtext": "Add client",
            "action_label": "Add Client"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "company",
            "industry",
            "employees",
            "status"
