            "company",
            "industry",
            "employees",
            "status"
          ],
          "required_fields": [
            "company",
            "industry"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/clients/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "company"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "company",
            "industry",
            "employees",
            "status"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "company",
                "industry",
                "employees",
                "status"
              ]
            }
          ]
        }
      }
    },
