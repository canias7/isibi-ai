{
  "_meta": {
    "app_name": "Inventory Management",
    "description": "Inventory Management management"
  },
  "entities": [
    {
      "name": "Item",
      "table": "items",
      "description": "Item",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "sku",
          "db_type": "VARCHAR(50) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "SKU-001",
          "help_text": "Stock keeping unit identifier"
        },
        {
          "name": "name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Enter name",
          "help_text": "Full name"
        },
        {
          "name": "category",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "quantity",
          "db_type": "INTEGER",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text",
          "validation": {
            "min": 0,
            "message": "Quantity must be a positive number"
          },
          "placeholder": "1",
          "help_text": "Number of units"
        },
        {
          "name": "reorder_level",
          "db_type": "INTEGER",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "cost",
          "db_type": "NUMERIC(10,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text",
          "validation": {
            "min": 0,
            "message": "Cost must be a positive number"
          },
          "placeholder": "0.00",
          "help_text": "Cost in USD"
        },
        {
          "name": "price",
          "db_type": "NUMERIC(10,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": false,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text",
          "validation": {
            "min": 0,
            "message": "Price must be a positive number"
          },
          "placeholder": "0.00",
          "help_text": "Price in USD"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": false,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "in_stock",
            "low",
            "out",
            "discontinued"
          ],
          "badge_colors": {
            "in_stock": "pink",
            "low": "blue",
            "out": "green",
            "discontinued": "amber"
          }
        },
        {
          "name": "total",
          "db_type": "NUMERIC(10,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text",
          "computed": {
            "formula": "quantity * price",
            "dependencies": [
              "quantity",
              "price"
            ]
          },
          "placeholder": "0.00",
          "help_text": "Total amount in USD"
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "sku",
            "name",
            "category",
            "quantity",
            "reorder_level",
            "cost",
            "total"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Items yet",
            "subtext": "Add item",
            "action_label": "Add Item"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "in_stock",
                "low",
                "out",
                "discontinued"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "sku",
            "name",
            "category"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "sku",
            "name",
            "category",
            "quantity",
            "reorder_level",
            "cost",
            "price",
            "status",
            "total"
          ],
          "required_fields": [
            "sku",
            "name"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "sku",
            "name",
            "category",
            "quantity",
            "reorder_level",
            "cost",
            "price",
            "status",
            "total"
          ],
          "required_fields": [
            "sku",
            "name"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/items/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "sku"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "sku",
            "name",
            "category",
            "quantity"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "sku",
                "name",
                "category",
                "quantity",
                "reorder_level",
                "cost",
                "total"
              ]
            }
          ]
        }
      }
    },
    {
