        {
          "name": "fee",
          "db_type": "NUMERIC(10,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "submitted",
            "review",
            "approved",
            "denied",
            "expired",
            "revoked"
          ],
          "badge_colors": {
            "submitted": "pink",
            "review": "blue",
            "approved": "green",
            "denied": "amber",
            "expired": "purple",
            "revoked": "red"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "applicant_name",
            "address",
            "type",
            "fee",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Permits yet",
            "subtext": "Add permit",
            "action_label": "Add Permit"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "applicant_name",
            "address",
            "type",
            "description",
            "fee",
            "status"
          ],
          "required_fields": [
            "applicant_name",
            "address"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "applicant_name",
            "address",
            "type",
            "description",
            "fee",
            "status"
          ],
          "required_fields": [
            "applicant_name",
            "address"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/permits/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "applicant_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "applicant_name",
            "address",
            "type",
            "fee"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "applicant_name",
                "address",
                "type",
                "fee",
                "status"
              ]
            }
          ]
        }
      }
    },
