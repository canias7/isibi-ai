      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Students",
      "route": "/students",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Student"
    },
    {
      "name": "Sessions",
      "route": "/sessions",
      "component": "EntityListPage",
      "layout": "app",
