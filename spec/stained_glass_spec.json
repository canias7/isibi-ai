          "primary_fields": [
            "client",
            "type",
            "dimensions",
            "price"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "client",
                "type",
                "dimensions",
                "price",
                "status"
              ]
            }
          ]
        }
      }
