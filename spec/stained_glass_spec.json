  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Commissions",
      "route": "/commissions",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Commission"
    },
    {
      "name": "Classs",
      "route": "/classes",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Class"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Commission",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Total Price",
        "entity": "Commission",
        "method": "sum",
        "field": "price",
        "icon": "DollarSign",
        "color": "amber"
      },
      {
        "label": "Total Classs",
        "entity": "Class",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Active Classs",
        "entity": "Class",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "scheduled"
        },
        "icon": "Activity",
        "color": "green"
      }
    ]
  },
