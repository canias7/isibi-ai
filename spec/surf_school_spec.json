        "list_view": {
          "layout": "table",
          "columns": [
            "student_name",
            "instructor_name",
            "date",
            "time",
            "type",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Lessons yet",
            "subtext": "Add your first lesson",
            "action_label": "Add Lesson"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            },
            {
              "name": "Calendar",
              "layout": "calendar",
              "date_field": "date"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "booked",
                "in_water",
                "completed",
                "cancelled"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "student_name",
            "instructor_name"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Completed",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "completed"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "student_name",
            "instructor_name",
            "date",
            "time",
            "type",
            "status"
          ],
          "required_fields": [
            "student_name",
            "instructor_name"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "student_name",
            "instructor_name",
            "date",
            "time",
            "type",
            "status"
          ],
          "required_fields": [
            "student_name",
            "instructor_name"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/lessons/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "student_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "student_name",
            "instructor_name",
            "date",
            "time"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "student_name",
                "instructor_name",
                "date",
                "time",
                "type",
                "status"
              ]
            }
          ]
        }
      }
    },
