{
  "_meta": {
    "app_name": "Hot Air Balloon",
    "description": "Balloon rides"
  },
  "entities": [
    {
      "name": "Flight",
      "table": "flights",
      "description": "Flight entity",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "date",
          "db_type": "DATE NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "date_input",
          "display_component": "date"
        },
        {
          "name": "time",
          "db_type": "TIME",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "pilot_name",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "passengers",
          "db_type": "INTEGER",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "type",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "sunrise",
            "sunset",
            "private",
            "proposal",
            "festival"
          ],
          "badge_colors": {
            "sunrise": "pink",
            "sunset": "blue",
            "private": "green",
            "proposal": "amber",
            "festival": "purple"
          }
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "scheduled",
            "inflating",
            "flying",
            "landed",
            "cancelled",
            "weather_hold"
          ],
          "badge_colors": {
            "scheduled": "pink",
            "inflating": "blue",
            "flying": "green",
            "landed": "amber",
            "cancelled": "purple",
            "weather_hold": "red"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "date",
            "time",
            "pilot_name",
            "passengers",
            "type",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Flights yet",
            "subtext": "Add your first flight",
            "action_label": "Add Flight"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "date",
            "time",
            "pilot_name",
            "passengers",
            "type",
            "status"
          ],
          "required_fields": [
            "date",
            "time"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "date",
            "time",
            "pilot_name",
            "passengers",
            "type",
            "status"
          ],
          "required_fields": [
            "date",
            "time"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/flights/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "date"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "date",
            "time",
            "pilot_name",
            "passengers"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "date",
                "time",
                "pilot_name",
                "passengers",
                "type",
                "status"
              ]
            }
          ]
        }
      }
    },
