{
  "_meta": {
    "app_name": "User Feedback",
    "description": "User Feedback management"
  },
  "entities": [
    {
      "name": "Feedback",
      "table": "feedback",
      "description": "Feedback",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "title",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Enter title",
          "help_text": "Short descriptive title"
        },
        {
          "name": "user_email",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "category",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "bug",
            "feature",
            "improvement",
            "question",
            "praise",
            "complaint"
          ],
          "badge_colors": {
            "bug": "pink",
            "feature": "blue",
            "improvement": "green",
            "question": "amber",
            "praise": "purple",
            "complaint": "red"
          }
        },
        {
          "name": "sentiment",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "positive",
            "neutral",
            "negative"
          ],
          "badge_colors": {
            "positive": "pink",
            "neutral": "blue",
            "negative": "green"
          }
        },
        {
          "name": "description",
          "db_type": "TEXT",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": false,
          "show_in_form": true,
          "input_component": "textarea",
          "display_component": "text",
          "placeholder": "Enter description...",
          "help_text": "Brief description"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "new",
            "triaged",
            "in_progress",
            "resolved",
            "wont_fix"
          ],
          "badge_colors": {
            "new": "pink",
            "triaged": "blue",
            "in_progress": "green",
            "resolved": "amber",
            "wont_fix": "purple"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "title",
            "user_email",
            "category",
            "sentiment",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Feedbacks yet",
            "subtext": "Add feedback",
            "action_label": "Add Feedback"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "new",
                "triaged",
                "in_progress",
                "resolved",
                "wont_fix"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "title",
            "user_email",
            "description"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Resolved",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "resolved"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "user_email",
            "category",
            "sentiment",
            "description",
            "status"
          ],
          "required_fields": [
            "title",
            "user_email"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "user_email",
            "category",
            "sentiment",
            "description",
            "status"
          ],
          "required_fields": [
            "title",
            "user_email"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/feedback/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "title"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "title",
            "user_email",
            "category",
            "sentiment"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "title",
                "user_email",
                "category",
                "sentiment",
                "status"
              ]
            }
          ]
        }
      }
    },
    {
