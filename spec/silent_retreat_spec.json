          "type": "SlideOverForm",
          "field_order": [
            "title",
            "location",
            "dates",
            "duration_days",
            "tradition",
            "price",
            "status"
          ],
          "required_fields": [
            "title",
            "location"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/retreats/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "title"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "title",
            "location",
            "dates",
            "duration_days"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "title",
                "location",
                "dates",
                "duration_days",
                "tradition",
                "price"
              ]
            }
          ]
        }
      }
