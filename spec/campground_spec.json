        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "number",
            "type",
            "capacity",
            "nightly_rate",
            "amenities",
            "status"
          ],
          "required_fields": [
            "number",
            "type"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/sites/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "number"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "number",
            "type",
            "capacity",
            "nightly_rate"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "number",
                "type",
                "capacity",
                "nightly_rate",
                "status"
              ]
            }
          ]
        }
