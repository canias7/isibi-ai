            "scheduled": "pink",
            "in_bay": "blue",
            "completed": "green"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "customer_name",
            "vehicle_info",
            "type",
            "tire_size",
            "price",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Services yet",
            "subtext": "Add service",
            "action_label": "Add Service"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "vehicle_info",
            "type",
            "tire_size",
            "price",
            "status"
          ],
          "required_fields": [
            "customer_name",
            "vehicle_info"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "vehicle_info",
            "type",
            "tire_size",
            "price",
            "status"
          ],
          "required_fields": [
            "customer_name",
            "vehicle_info"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/services/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "customer_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "customer_name",
            "vehicle_info",
            "type",
            "tire_size"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "customer_name",
                "vehicle_info",
                "type",
                "tire_size",
                "price",
                "status"
              ]
            }
          ]
        }
      }
    },
