            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "phone",
            "insurance"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "phone",
                "insurance"
              ]
            }
          ]
        }
      }
    }
  ],
  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Jobs",
      "route": "/jobs",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Job"
    },
    {
      "name": "Customers",
      "route": "/customers",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Customer"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Job",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Jobs",
        "entity": "Job",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "in_progress"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Completed Jobs",
        "entity": "Job",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "approved"
        },
        "icon": "CheckCircle",
        "color": "emerald"
      },
      {
        "label": "Total Estimate",
        "entity": "Job",
        "method": "sum",
        "field": "estimate",
        "icon": "DollarSign",
        "color": "amber"
      }
    ]
  },
  "design_system": {
    "theme": "light",
    "colors": {
      "primary": "#ec4899",
      "secondary": "#64748b",
      "background": "#ffffff",
      "surface": "#f8fafc",
      "text": "#0f172a",
      "muted": "#94a3b8"
    },
    "spacing": {
      "page_padding": "24px",
      "card_padding": "16px",
      "gap": "16px"
    },
    "buttons": {
      "primary": {
        "bg": "bg-pink-500",
        "text": "text-white",
        "hover": "hover:bg-pink-600"
      }
    },
    "table": {
      "header_bg": "bg-gray-50",
      "row_hover": "hover:bg-gray-50",
      "border": "border-gray-200"
    },
    "typography": {
      "heading": "text-gray-900 font-semibold",
      "body": "text-gray-700",
      "muted": "text-gray-400"
    }
  },
  "pagination": {
    "type": "cursor",
    "default_page_size": 25,
    "max_page_size": 100
  }
}
