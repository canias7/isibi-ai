          "name": "damage_type",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "collision",
            "dent",
            "paint",
            "rust",
            "glass",
            "frame"
          ],
          "badge_colors": {
            "collision": "pink",
            "dent": "blue",
            "paint": "green",
            "rust": "amber",
            "glass": "purple",
            "frame": "red"
          }
        },
        {
          "name": "estimate",
          "db_type": "NUMERIC(10,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "estimate",
            "approved",
            "in_progress",
            "painting",
            "reassembly",
            "ready"
          ],
          "badge_colors": {
            "estimate": "pink",
            "approved": "blue",
            "in_progress": "green",
            "painting": "amber",
            "reassembly": "purple",
            "ready": "red"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "customer_name",
            "vehicle_info",
            "damage_type",
            "estimate",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Jobs yet",
            "subtext": "Add your first job",
            "action_label": "Add Job"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "vehicle_info",
            "damage_type",
            "estimate",
            "status"
          ],
          "required_fields": [
            "customer_name",
            "vehicle_info"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "vehicle_info",
            "damage_type",
            "estimate",
            "status"
          ],
          "required_fields": [
            "customer_name",
            "vehicle_info"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/jobs/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "customer_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "customer_name",
            "vehicle_info",
            "damage_type",
            "estimate"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "customer_name",
                "vehicle_info",
                "damage_type",
                "estimate",
                "status"
              ]
            }
          ]
        }
      }
    },
