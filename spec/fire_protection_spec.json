  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Systems",
      "route": "/systems",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "System"
    },
    {
      "name": "Inspections",
      "route": "/inspections",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Inspection"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "System",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Total Inspections",
        "entity": "Inspection",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Active Inspections",
        "entity": "Inspection",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "scheduled"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Completed Inspections",
        "entity": "Inspection",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "completed"
        },
        "icon": "CheckCircle",
        "color": "emerald"
      }
    ]
  },
  "design_system": {
    "theme": "light",
