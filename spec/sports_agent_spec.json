  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Athletes",
      "route": "/athletes",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Athlete"
    },
    {
      "name": "Deals",
      "route": "/deals",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Deal"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Athlete",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Athletes",
        "entity": "Athlete",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "active"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Total Contract Value",
        "entity": "Athlete",
        "method": "sum",
        "field": "contract_value",
        "icon": "DollarSign",
        "color": "amber"
      },
      {
        "label": "Total Deals",
        "entity": "Deal",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      }
    ]
  },
