      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "sport",
            "team",
            "contract_value",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Athletes yet",
            "subtext": "Add athlete",
            "action_label": "Add Athlete"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "active",
                "free_agent",
                "retired"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "name",
            "team"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "sport",
            "team",
            "contract_value",
            "status"
          ],
          "required_fields": [
            "name",
            "sport"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "sport",
            "team",
            "contract_value",
            "status"
          ],
          "required_fields": [
            "name",
            "sport"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/athletes/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "sport",
            "team",
            "contract_value"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "sport",
                "team",
                "contract_value",
                "status"
              ]
            }
          ]
        }
      }
    },
