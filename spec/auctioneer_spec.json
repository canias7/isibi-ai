  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Listings",
      "route": "/listings",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Listing"
    },
    {
      "name": "Bids",
      "route": "/bids",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Bid"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Listing",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Listings",
        "entity": "Listing",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "active"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Total Start Price",
        "entity": "Listing",
        "method": "sum",
        "field": "start_price",
        "icon": "DollarSign",
        "color": "amber"
      },
      {
        "label": "Total Bids",
        "entity": "Bid",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      }
    ]
