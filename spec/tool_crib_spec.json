          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "hand",
            "power",
            "measuring",
            "safety",
            "specialty"
          ],
          "badge_colors": {
            "hand": "pink",
            "power": "blue",
            "measuring": "green",
            "safety": "amber",
            "specialty": "purple"
          }
        },
        {
          "name": "serial",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
