        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "phone",
            "address",
            "tank_count"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Clients yet",
            "subtext": "Create your first client",
            "action_label": "Add Client"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "name",
            "phone",
            "address",
            "email",
            "company"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "phone",
            "address",
            "tank_count"
          ],
          "required_fields": [
            "name",
            "phone"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "phone",
            "address",
            "tank_count"
          ],
          "required_fields": [
            "name",
            "phone"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/clients/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "phone",
            "address",
            "tank_count"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "phone",
                "address",
                "tank_count"
              ]
            }
          ]
        }
      }
    },
