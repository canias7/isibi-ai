{
  "_meta": {
    "app_name": "Modeling Agency",
    "description": "Modeling Agency management"
  },
  "entities": [
    {
      "name": "Model",
      "table": "models",
      "description": "Model",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Enter name",
          "help_text": "Full name"
        },
        {
          "name": "email",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "validation": {
            "pattern": "^[^@]+@[^@]+\\.[^@]+$",
            "message": "Enter a valid email address"
          },
          "placeholder": "email@example.com",
          "help_text": "Primary email address"
        },
        {
          "name": "type",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "fashion",
            "commercial",
            "fitness",
            "plus_size",
            "petite",
            "child"
          ],
          "badge_colors": {
            "fashion": "pink",
            "commercial": "blue",
            "fitness": "green",
            "plus_size": "amber",
            "petite": "purple",
            "child": "red"
          }
        },
        {
          "name": "height",
          "db_type": "VARCHAR(20)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "active",
            "developing",
            "retired"
          ],
          "badge_colors": {
            "active": "pink",
            "developing": "blue",
            "retired": "green"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "email",
            "type",
            "height",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Models yet",
            "subtext": "Add model",
            "action_label": "Add Model"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "active",
                "developing",
                "retired"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "name",
            "email",
            "height"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "email",
            "type",
            "height",
            "status"
          ],
          "required_fields": [
            "name",
            "email"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "email",
            "type",
            "height",
            "status"
          ],
          "required_fields": [
            "name",
            "email"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/models/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "email",
            "type",
            "height"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "email",
                "type",
                "height",
                "status"
              ]
            }
          ]
        }
      }
    },
