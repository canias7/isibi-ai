  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Models",
      "route": "/models",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Model"
    },
    {
      "name": "Bookings",
      "route": "/bookings",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Booking"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Model",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Models",
        "entity": "Model",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "active"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Total Bookings",
        "entity": "Booking",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Active Bookings",
        "entity": "Booking",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "confirmed"
        },
        "icon": "Activity",
        "color": "green"
      }
    ]
  },
