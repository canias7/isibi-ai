      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "customer_name",
            "item",
            "fabric_type",
            "price",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Jobs yet",
            "subtext": "Add job",
            "action_label": "Add Job"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "item",
            "fabric_type",
            "price",
            "status"
          ],
          "required_fields": [
            "customer_name",
            "item"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "item",
            "fabric_type",
            "price",
            "status"
          ],
          "required_fields": [
            "customer_name",
            "item"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/jobs/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "customer_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "customer_name",
            "item",
            "fabric_type",
            "price"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "customer_name",
                "item",
                "fabric_type",
                "price",
                "status"
              ]
            }
          ]
        }
      }
    },
