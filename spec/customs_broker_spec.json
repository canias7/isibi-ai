            "entry_number"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/entries/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "importer"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "importer",
            "entry_number",
            "port",
            "value"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "importer",
                "entry_number",
                "port",
                "value",
                "duty"
              ]
            }
          ]
        }
      }
