{
  "_meta": {
    "app_name": "Zip Coaster ",
    "description": "Zip Coaster  management"
  },
  "entities": [
    {
      "name": "Booking",
      "table": "bookings",
      "description": "Booking",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "customer",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "date",
          "db_type": "DATE",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "date_input",
          "display_component": "date"
        },
        {
          "name": "time",
          "db_type": "TIME",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "duration",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "price",
          "db_type": "NUMERIC(10,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "booked",
            "checked_in",
            "active",
            "completed",
            "cancelled"
          ],
          "badge_colors": {
            "booked": "pink",
            "checked_in": "blue",
            "active": "green",
            "completed": "amber",
            "cancelled": "purple"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "customer",
            "date",
            "time",
            "duration",
            "price",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Bookings yet",
            "subtext": "Add booking",
            "action_label": "Add Booking"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer",
            "date",
            "time",
            "duration",
            "price",
            "status"
          ],
          "required_fields": [
            "customer",
            "date"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer",
            "date",
            "time",
            "duration",
            "price",
            "status"
          ],
          "required_fields": [
            "customer",
            "date"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/bookings/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "customer"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "customer",
            "date",
            "time",
            "duration"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "customer",
                "date",
                "time",
                "duration",
                "price",
                "status"
              ]
            }
          ]
        }
      }
    },
