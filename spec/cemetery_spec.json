{
  "_meta": {
    "app_name": "Cemetery",
    "description": "Cemetery management"
  },
  "entities": [
    {
      "name": "Plot",
      "table": "plots",
      "description": "Burial plot",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "section",
          "db_type": "VARCHAR(50) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "lot_number",
          "db_type": "VARCHAR(20)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "type",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "single",
            "double",
            "family",
            "cremation",
            "mausoleum"
          ],
          "badge_colors": {
            "single": "pink",
            "double": "blue",
            "family": "green",
            "cremation": "amber",
            "mausoleum": "purple"
          }
        },
        {
          "name": "price",
          "db_type": "NUMERIC(10,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "available",
            "reserved",
            "occupied"
          ],
          "badge_colors": {
            "available": "pink",
            "reserved": "blue",
            "occupied": "green"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "section",
            "lot_number",
            "type",
            "price",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Plots yet",
            "subtext": "Create your first plot",
            "action_label": "Add Plot"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "section",
            "lot_number",
            "type",
            "price",
            "status"
          ],
          "required_fields": [
            "section",
            "lot_number"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "section",
            "lot_number",
            "type",
            "price",
            "status"
          ],
          "required_fields": [
            "section",
            "lot_number"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/plots/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "section"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "section",
            "lot_number",
            "type",
            "price"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "section",
                "lot_number",
                "type",
                "price",
                "status"
              ]
            }
          ]
        }
      }
    },
