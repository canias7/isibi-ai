      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Plots",
      "route": "/plots",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Plot"
    },
    {
      "name": "Interments",
      "route": "/interments",
