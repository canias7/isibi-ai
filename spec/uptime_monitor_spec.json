          "route": "/monitors/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "url",
            "check_interval_sec",
            "type"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "url",
                "check_interval_sec",
                "type",
                "uptime_pct",
                "status"
              ]
            }
          ]
        }
      }
