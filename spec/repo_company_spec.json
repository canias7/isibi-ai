  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Assignments",
      "route": "/assignments",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Assignment"
    },
    {
      "name": "Agents",
      "route": "/agents",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Agent"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Assignment",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Completed Assignments",
        "entity": "Assignment",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "closed"
        },
        "icon": "CheckCircle",
        "color": "emerald"
      },
      {
        "label": "Total Balance Owed",
        "entity": "Assignment",
        "method": "sum",
        "field": "balance_owed",
        "icon": "DollarSign",
        "color": "amber"
      },
      {
        "label": "Total Agents",
        "entity": "Agent",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      }
    ]
  },
  "design_system": {
    "theme": "light",
