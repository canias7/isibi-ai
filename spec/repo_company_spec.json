{
  "_meta": {
    "app_name": "Repo Company",
    "description": "Repo Company management"
  },
  "entities": [
    {
      "name": "Assignment",
      "table": "assignments",
      "description": "Assignment",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "lender",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "debtor",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "vehicle_info",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "vin",
          "db_type": "VARCHAR(17)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "17-character VIN",
          "help_text": "Vehicle identification number"
        },
        {
          "name": "balance_owed",
          "db_type": "NUMERIC(14,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "assigned",
            "locating",
            "attempt",
            "recovered",
            "returned_to_lender",
            "closed"
          ],
          "badge_colors": {
            "assigned": "pink",
            "locating": "blue",
            "attempt": "green",
            "recovered": "amber",
            "returned_to_lender": "purple",
            "closed": "red"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "lender",
            "debtor",
            "vehicle_info",
            "vin",
            "balance_owed",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Assignments yet",
            "subtext": "Add assignment",
            "action_label": "Add Assignment"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "assigned",
                "locating",
                "attempt",
                "recovered",
                "returned_to_lender",
                "closed"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "lender",
            "debtor",
            "vehicle_info",
            "vin"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Closed",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "closed"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "lender",
            "debtor",
            "vehicle_info",
            "vin",
            "balance_owed",
            "status"
          ],
          "required_fields": [
            "lender",
            "debtor"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "lender",
            "debtor",
            "vehicle_info",
            "vin",
            "balance_owed",
            "status"
          ],
          "required_fields": [
            "lender",
            "debtor"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/assignments/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "lender"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "lender",
            "debtor",
            "vehicle_info",
            "vin"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "lender",
                "debtor",
                "vehicle_info",
                "vin",
                "balance_owed",
                "status"
              ]
            }
          ]
        }
      }
    },
