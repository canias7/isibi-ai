            "parent_name",
            "parent_phone",
            "status"
          ],
          "required_fields": [
            "name",
            "email"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/students/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "email",
            "grade",
            "parent_name"
          ],
          "tabs": [
            {
              "name": "Overview",
