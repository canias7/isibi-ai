            "active",
            "paused",
            "achieved"
          ],
          "badge_colors": {
            "active": "pink",
            "paused": "blue",
            "achieved": "green"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
