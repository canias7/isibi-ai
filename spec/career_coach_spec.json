  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Clients",
      "route": "/clients",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Client"
    },
    {
      "name": "Sessions",
      "route": "/sessions",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Session"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Client",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Clients",
        "entity": "Client",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "active"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Total Sessions",
        "entity": "Session",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Active Sessions",
        "entity": "Session",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "scheduled"
        },
        "icon": "Activity",
        "color": "green"
      }
    ]
  },
