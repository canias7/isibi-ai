          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "email",
            "current_role",
            "target_role",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Clients yet",
            "subtext": "Add client",
            "action_label": "Add Client"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "active",
                "paused",
                "achieved"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "name",
            "email",
            "current_role",
            "target_role"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "email",
            "current_role",
            "target_role",
            "status"
          ],
          "required_fields": [
            "name",
            "email"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "email",
            "current_role",
            "target_role",
            "status"
          ],
          "required_fields": [
            "name",
            "email"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/clients/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "email",
            "current_role",
            "target_role"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "email",
                "current_role",
                "target_role",
                "status"
              ]
            }
          ]
        }
      }
    },
