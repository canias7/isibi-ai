        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "phone",
            "license",
            "experience_years",
            "specialties",
            "status"
          ],
          "required_fields": [
            "name",
            "phone"
          ],
          "prefilled": true
