  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Guard",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Total Posts",
        "entity": "Post",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Active Posts",
        "entity": "Post",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "open"
        },
        "icon": "Activity",
        "color": "green"
      },
