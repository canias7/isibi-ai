          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "style",
            "abv",
            "price"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "style",
                "abv",
                "price",
                "status"
              ]
            }
          ]
        }
      }
