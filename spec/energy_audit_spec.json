  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Audit",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Audits",
        "entity": "Audit",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "scheduled"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Total Annual Energy Cost",
        "entity": "Audit",
        "method": "sum",
        "field": "annual_energy_cost",
        "icon": "DollarSign",
        "color": "amber"
      },
      {
        "label": "Total Recommendations",
        "entity": "Recommendation",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      }
    ]
  },
