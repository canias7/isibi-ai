          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Audits yet",
            "subtext": "Add audit",
            "action_label": "Add Audit"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "scheduled",
                "data_collection",
                "analysis",
                "modeling",
                "report",
                "presented"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
