            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client",
            "address",
            "type",
            "annual_energy_cost",
            "savings_potential_pct",
            "status"
          ],
          "required_fields": [
            "client",
            "address"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client",
            "address",
            "type",
            "annual_energy_cost",
            "savings_potential_pct",
            "status"
          ],
          "required_fields": [
            "client",
            "address"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/audits/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "client"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "client",
            "address",
            "type",
            "annual_energy_cost"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "client",
                "address",
                "type",
                "annual_energy_cost",
                "savings_potential_pct",
                "status"
              ]
            }
          ]
        }
      }
    },
