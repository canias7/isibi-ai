{
  "_meta": {
    "app_name": "Welding Shop",
    "description": "Welding fabrication"
  },
  "entities": [
    {
      "name": "Project",
      "table": "projects",
      "description": "Project",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "customer_name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "description",
          "db_type": "TEXT",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": false,
          "show_in_form": true,
          "input_component": "textarea",
          "display_component": "text",
          "placeholder": "Enter description...",
          "help_text": "Brief description"
        },
        {
          "name": "material",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "mild_steel",
            "stainless",
            "aluminum",
            "cast_iron",
            "titanium"
          ],
          "badge_colors": {
            "mild_steel": "pink",
            "stainless": "blue",
            "aluminum": "green",
            "cast_iron": "amber",
            "titanium": "purple"
          }
        },
        {
          "name": "process",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "mig",
            "tig",
            "stick",
            "flux_core",
            "oxy_fuel"
          ],
          "badge_colors": {
            "mig": "pink",
            "tig": "blue",
            "stick": "green",
            "flux_core": "amber",
            "oxy_fuel": "purple"
          }
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "quoting",
            "approved",
            "fabricating",
            "welding",
            "finishing",
            "delivered"
          ],
          "badge_colors": {
            "quoting": "pink",
            "approved": "blue",
            "fabricating": "green",
            "welding": "amber",
            "finishing": "purple",
            "delivered": "red"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "customer_name",
            "material",
            "process",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Projects yet",
            "subtext": "Add project",
            "action_label": "Add Project"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "quoting",
                "approved",
                "fabricating",
                "welding",
                "finishing",
                "delivered"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "customer_name",
            "description"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Approved",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "approved"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "description",
            "material",
            "process",
            "status"
          ],
          "required_fields": [
            "customer_name",
            "description"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer_name",
            "description",
            "material",
            "process",
            "status"
          ],
          "required_fields": [
            "customer_name",
            "description"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/projects/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "customer_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "customer_name",
            "material",
            "process",
            "status"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "customer_name",
                "material",
                "process",
                "status"
              ]
            }
          ]
        }
      }
    },
