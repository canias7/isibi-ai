  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Members",
      "route": "/members",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Member"
    },
    {
      "name": "Events",
      "route": "/events",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Event"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Member",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Members",
        "entity": "Member",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "active"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Total Events",
        "entity": "Event",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Active Events",
        "entity": "Event",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "active"
        },
        "icon": "Activity",
        "color": "green"
      }
    ]
  },
  "design_system": {
    "theme": "light",
