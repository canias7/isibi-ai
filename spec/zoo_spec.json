            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "species",
            "habitat",
            "age",
            "sex",
            "status"
          ],
          "required_fields": [
            "name",
            "species"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "species",
            "habitat",
            "age",
            "sex",
            "status"
          ],
          "required_fields": [
            "name",
            "species"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/animals/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "species",
            "habitat",
            "age"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "species",
                "habitat",
                "age",
                "sex",
                "status"
              ]
            }
          ]
        }
      }
    },
