            "icon": "Box",
            "heading": "No Animals yet",
            "subtext": "Add your first animal",
            "action_label": "Add Animal"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
