            "espresso",
            "drip",
            "cold_brew",
            "tea",
            "pastry",
            "sandwich"
          ],
          "badge_colors": {
            "espresso": "amber",
            "drip": "blue",
            "cold_brew": "blue",
            "tea": "green",
            "pastry": "pink",
            "sandwich": "purple"
