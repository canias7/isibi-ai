  "dashboard": {
    "stat_cards": [
      {
        "label": "Total Products",
        "entity": "Product",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Total Price",
        "entity": "Product",
        "method": "sum",
        "field": "price",
        "icon": "DollarSign",
        "color": "amber"
      },
      {
        "label": "Total Orders",
        "entity": "Order",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Active Orders",
        "entity": "Order",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "pending"
        },
        "icon": "Activity",
