        "list_view": {
          "layout": "table",
          "columns": [
            "subject",
            "client",
            "type",
            "scope",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Checks yet",
            "subtext": "Add check",
            "action_label": "Add Check"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "ordered",
                "searching",
                "review",
                "completed"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "subject",
            "client"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Completed",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "completed"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "subject",
            "client",
            "type",
            "scope",
            "status"
          ],
          "required_fields": [
            "subject",
            "client"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "subject",
            "client",
            "type",
            "scope",
            "status"
          ],
          "required_fields": [
            "subject",
            "client"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/checks/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "subject"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "subject",
            "client",
            "type",
            "scope"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "subject",
                "client",
                "type",
                "scope",
                "status"
              ]
            }
          ]
        }
      }
    },
