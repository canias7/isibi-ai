        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Podcasts",
        "entity": "Podcast",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "active"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Completed Podcasts",
        "entity": "Podcast",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "completed"
