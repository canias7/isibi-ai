  "dashboard": {
    "stat_cards": [
      {
        "label": "Total Events",
        "entity": "Event",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Events",
        "entity": "Event",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "booked"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Completed Events",
        "entity": "Event",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "delivered"
        },
        "icon": "CheckCircle",
        "color": "emerald"
      },
      {
        "label": "Total Total",
        "entity": "Event",
        "method": "sum",
        "field": "total",
        "icon": "DollarSign",
        "color": "amber"
      }
    ]
  },
