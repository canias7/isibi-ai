      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "title",
            "author",
            "type",
            "filing_date",
            "registration_number",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Registrations yet",
            "subtext": "Add registration",
            "action_label": "Add Registration"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "author",
            "type",
            "filing_date",
            "registration_number",
            "status"
          ],
          "required_fields": [
            "title",
            "author"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "title",
            "author",
            "type",
            "filing_date",
            "registration_number",
            "status"
          ],
          "required_fields": [
            "title",
            "author"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/registrations/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "title"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "title",
            "author",
            "type",
            "filing_date"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "title",
                "author",
                "type",
                "filing_date",
                "registration_number",
                "status"
              ]
            }
          ]
        }
      }
    },
