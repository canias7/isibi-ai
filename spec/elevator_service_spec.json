      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "building",
            "type",
            "floors",
            "last_inspection",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Units yet",
            "subtext": "Add unit",
            "action_label": "Add Unit"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "building",
            "type",
            "floors",
            "last_inspection",
            "status"
          ],
          "required_fields": [
            "building",
            "type"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "building",
            "type",
            "floors",
            "last_inspection",
            "status"
          ],
          "required_fields": [
            "building",
            "type"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/units/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "building"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "building",
            "type",
            "floors",
            "last_inspection"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "building",
                "type",
                "floors",
                "last_inspection",
                "status"
              ]
            }
          ]
        }
      }
    },
