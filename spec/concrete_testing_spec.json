        "list_view": {
          "layout": "table",
          "columns": [
            "project",
            "contractor",
            "type",
            "location",
            "result",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Tests yet",
            "subtext": "Add test",
            "action_label": "Add Test"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "cast",
                "curing",
                "testing",
                "reported"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "project",
            "contractor",
            "location",
            "result"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "project",
            "contractor",
            "type",
            "location",
            "result",
            "status"
          ],
          "required_fields": [
            "project",
            "contractor"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "project",
            "contractor",
            "type",
            "location",
            "result",
            "status"
          ],
          "required_fields": [
            "project",
            "contractor"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/tests/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "project"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "project",
            "contractor",
            "type",
            "location"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "project",
                "contractor",
                "type",
                "location",
                "result",
                "status"
              ]
            }
          ]
        }
      }
    },
