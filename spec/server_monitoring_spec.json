            "hostname",
            "ip_address",
            "provider",
            "cpu_cores",
            "ram_gb",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Servers yet",
            "subtext": "Create your first server",
            "action_label": "Add Server"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "healthy",
                "warning",
                "critical",
                "offline",
                "maintenance"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "hostname",
            "ip_address"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "hostname",
            "ip_address",
            "provider",
            "cpu_cores",
            "ram_gb",
            "status"
          ],
          "required_fields": [
            "hostname",
            "ip_address"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "hostname",
            "ip_address",
            "provider",
            "cpu_cores",
            "ram_gb",
            "status"
          ],
          "required_fields": [
            "hostname",
            "ip_address"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/servers/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "hostname"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "hostname",
            "ip_address",
            "provider",
            "cpu_cores"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "hostname",
                "ip_address",
                "provider",
                "cpu_cores",
                "ram_gb",
                "status"
              ]
            }
          ]
        }
      }
