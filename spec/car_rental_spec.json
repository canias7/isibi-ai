          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "plate",
            "make",
            "model",
            "year",
            "category",
            "daily_rate"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Vehicles yet",
            "subtext": "Add vehicle",
            "action_label": "Add Vehicle"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "available",
                "rented",
                "maintenance",
                "reserved"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "plate",
            "make",
            "model"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "plate",
            "make",
            "model",
            "year",
            "category",
            "daily_rate",
            "status"
          ],
          "required_fields": [
            "plate",
            "make"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "plate",
            "make",
            "model",
            "year",
            "category",
            "daily_rate",
            "status"
          ],
          "required_fields": [
            "plate",
            "make"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/vehicles/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "plate"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "plate",
            "make",
            "model",
            "year"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "plate",
                "make",
                "model",
                "year",
                "category",
                "daily_rate"
              ]
            }
          ]
        }
      }
    },
