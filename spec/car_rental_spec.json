  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Vehicles",
      "route": "/vehicles",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Vehicle"
    },
    {
      "name": "Rentals",
      "route": "/rentals",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Rental"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Vehicle",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Total Daily Rate",
        "entity": "Vehicle",
        "method": "sum",
        "field": "daily_rate",
        "icon": "DollarSign",
        "color": "amber"
      },
      {
        "label": "Total Rentals",
        "entity": "Rental",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Active Rentals",
        "entity": "Rental",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "active"
        },
        "icon": "Activity",
        "color": "green"
      }
    ]
  },
  "design_system": {
    "theme": "light",
