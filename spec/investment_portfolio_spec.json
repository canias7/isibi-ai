          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "growth",
            "income",
            "balanced",
            "aggressive",
            "conservative",
            "index"
          ],
          "badge_colors": {
            "growth": "green",
            "income": "blue",
            "balanced": "purple",
            "aggressive": "red",
            "conservative": "amber",
            "index": "slate"
          }
        },
        {
          "name": "currency",
          "db_type": "CHAR(3) NOT NULL DEFAULT 'USD'",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "total_value",
          "db_type": "NUMERIC(15,2) NOT NULL",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "number_input",
          "display_component": "currency",
          "computed": "SUM(assets.current_value)",
          "validation": {
            "min": 0
          }
        },
        {
          "name": "total_cost",
          "db_type": "NUMERIC(15,2) NOT NULL",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "number_input",
          "display_component": "currency",
          "computed": "SUM(assets.cost_basis)",
          "validation": {
            "min": 0
          }
        },
        {
          "name": "total_gain_loss",
          "db_type": "NUMERIC(15,2) NOT NULL",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "number_input",
          "display_component": "currency",
          "computed": "total_value - total_cost",
          "validation": {
            "min": 0
          }
        },
        {
          "name": "total_return_pct",
          "db_type": "NUMERIC(5,2)",
          "ts_type": "number",
          "nullable": true,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "number_input",
          "display_component": "percentage",
          "computed": "total_gain_loss / total_cost * 100"
