          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Enter name",
          "help_text": "Full name or title"
        },
        {
          "name": "portfolio_type",
          "db_type": "VARCHAR(30) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "growth",
            "income",
            "balanced",
            "aggressive",
            "conservative",
            "index"
          ],
          "badge_colors": {
            "growth": "green",
            "income": "blue",
            "balanced": "purple",
            "aggressive": "red",
            "conservative": "amber",
            "index": "slate"
          },
          "placeholder": "Select portfolio type"
        },
        {
          "name": "currency",
          "db_type": "CHAR(3) NOT NULL DEFAULT 'USD'",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Enter currency"
        },
        {
          "name": "total_value",
          "db_type": "NUMERIC(15,2) NOT NULL",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "number_input",
          "display_component": "currency",
          "computed": "SUM(assets.current_value)",
          "validation": {
            "min": 0
          },
          "placeholder": "0.00",
          "help_text": "Total amount"
        },
        {
          "name": "total_cost",
          "db_type": "NUMERIC(15,2) NOT NULL",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "number_input",
          "display_component": "currency",
          "computed": "SUM(assets.cost_basis)",
          "validation": {
            "min": 0
          },
          "placeholder": "0.00",
          "help_text": "Cost amount"
        },
        {
          "name": "total_gain_loss",
          "db_type": "NUMERIC(15,2) NOT NULL",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "number_input",
          "display_component": "currency",
          "computed": "total_value - total_cost",
          "validation": {
            "min": 0
          },
          "placeholder": "0.00",
          "help_text": "Total amount"
        },
        {
          "name": "total_return_pct",
          "db_type": "NUMERIC(5,2)",
          "ts_type": "number",
          "nullable": true,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "number_input",
          "display_component": "percentage",
          "computed": "total_gain_loss / total_cost * 100",
          "placeholder": "0.00",
          "help_text": "Total amount"
        },
        {
          "name": "benchmark",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
