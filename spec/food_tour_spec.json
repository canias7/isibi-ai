  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Tours",
      "route": "/tours",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
