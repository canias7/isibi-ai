  "modules": [
    {
      "name": "Dashboard",
      "route": "/dashboard",
      "component": "DashboardPage",
      "layout": "app",
      "sidebar_order": 1,
      "sidebar_icon": "LayoutDashboard"
    },
    {
      "name": "Databases",
      "route": "/databases",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 2,
      "sidebar_icon": "Box",
      "entity": "Database"
    },
    {
      "name": "Backups",
      "route": "/backups",
      "component": "EntityListPage",
      "layout": "app",
      "sidebar_order": 3,
      "sidebar_icon": "Box",
      "entity": "Backup"
    }
  ],
  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Database",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Total Size Gb",
        "entity": "Database",
        "method": "sum",
        "field": "size_gb",
        "icon": "DollarSign",
        "color": "amber"
      },
      {
        "label": "Total Backups",
        "entity": "Backup",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Completed Backups",
        "entity": "Backup",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "completed"
        },
        "icon": "CheckCircle",
        "color": "emerald"
      }
    ]
  },
  "design_system": {
    "theme": "light",
    "colors": {
      "primary": "#ec4899",
      "secondary": "#64748b",
      "background": "#ffffff",
      "surface": "#f8fafc",
      "text": "#0f172a",
      "muted": "#94a3b8"
    },
    "spacing": {
      "page_padding": "24px",
      "card_padding": "16px",
      "gap": "16px"
    },
    "buttons": {
      "primary": {
        "bg": "bg-pink-500",
        "text": "text-white",
        "hover": "hover:bg-pink-600"
      }
    },
    "table": {
      "header_bg": "bg-gray-50",
      "row_hover": "hover:bg-gray-50",
      "border": "border-gray-200"
    },
    "typography": {
      "heading": "text-gray-900 font-semibold",
      "body": "text-gray-700",
      "muted": "text-gray-400"
    }
  },
  "pagination": {
    "type": "cursor",
