            "title",
            "instructor_name"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/courses/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "title"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "title",
            "instructor_name",
            "category",
            "price"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "title",
                "instructor_name",
                "category",
                "price",
                "enrolled",
                "status"
