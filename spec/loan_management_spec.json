            "email",
            "phone",
            "credit_score",
            "income"
          ],
          "required_fields": [
            "name",
            "email"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "email",
            "phone",
            "credit_score",
            "income"
          ],
          "required_fields": [
            "name",
            "email"
