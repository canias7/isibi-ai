{
  "_meta": {
    "app_name": "Bail Bonds",
    "description": "Bail Bonds management"
  },
  "entities": [
    {
      "name": "Bond",
      "table": "bonds",
      "description": "Bond",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "defendant",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "charge",
          "db_type": "TEXT",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": false,
          "show_in_form": true,
          "input_component": "textarea",
          "display_component": "text"
        },
        {
          "name": "bail_amount",
          "db_type": "NUMERIC(14,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "premium",
          "db_type": "NUMERIC(10,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "court_date",
          "db_type": "DATE",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "date_input",
          "display_component": "date"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "posted",
            "active",
            "exonerated",
            "forfeited",
            "surrendered"
          ],
          "badge_colors": {
            "posted": "pink",
            "active": "blue",
            "exonerated": "green",
            "forfeited": "amber",
            "surrendered": "purple"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "defendant",
            "bail_amount",
            "premium",
            "court_date",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Bonds yet",
            "subtext": "Add bond",
            "action_label": "Add Bond"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "defendant",
            "charge",
            "bail_amount",
            "premium",
            "court_date",
            "status"
          ],
          "required_fields": [
            "defendant",
            "charge"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "defendant",
            "charge",
            "bail_amount",
            "premium",
            "court_date",
            "status"
          ],
          "required_fields": [
            "defendant",
            "charge"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/bonds/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "defendant"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "defendant",
            "bail_amount",
            "premium",
            "court_date"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "defendant",
                "bail_amount",
                "premium",
                "court_date",
                "status"
              ]
            }
          ]
        }
      }
    },
