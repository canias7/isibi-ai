{
  "_meta": {
    "app_name": "Warehouse Manager",
    "description": "Warehouse and inventory management"
  },
  "entities": [
    {
      "name": "Product",
      "table": "products",
      "description": "Stored product",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "sku",
          "db_type": "VARCHAR(50) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "SKU-001",
          "help_text": "Stock keeping unit identifier"
        },
        {
          "name": "name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Enter name",
          "help_text": "Full name"
        },
        {
          "name": "category",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "quantity",
          "db_type": "INTEGER NOT NULL DEFAULT 0",
          "ts_type": "number",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text",
          "validation": {
            "min": 0,
            "message": "Quantity must be a positive number"
          },
          "placeholder": "1",
          "help_text": "Number of units"
        },
        {
          "name": "location",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "e.g. Building A, Room 101",
          "help_text": "Physical location"
        },
        {
          "name": "reorder_point",
          "db_type": "INTEGER NOT NULL DEFAULT 10",
          "ts_type": "number",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "in_stock",
            "low_stock",
            "out_of_stock",
            "discontinued"
          ],
          "badge_colors": {
            "in_stock": "green",
            "low_stock": "amber",
            "out_of_stock": "red",
            "discontinued": "slate"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "sku",
            "name",
            "category",
            "quantity",
            "location",
            "reorder_point"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Products yet",
            "subtext": "Create your first product",
            "action_label": "Add Product"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "in_stock",
                "low_stock",
                "out_of_stock",
                "discontinued"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "sku",
            "name",
            "category",
            "location"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "sku",
            "name",
            "category",
            "quantity",
            "location",
            "reorder_point",
            "status"
          ],
          "required_fields": [
            "sku",
            "name"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "sku",
            "name",
            "category",
            "quantity",
            "location",
            "reorder_point",
            "status"
          ],
          "required_fields": [
            "sku",
            "name"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/products/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "sku"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "sku",
            "name",
            "category",
            "quantity"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "sku",
                "name",
                "category",
                "quantity",
                "location",
                "reorder_point",
                "status"
              ]
            }
          ]
        }
      }
    },
