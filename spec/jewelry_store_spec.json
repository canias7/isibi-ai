{
  "_meta": {
    "app_name": "Jewelry Store",
    "description": "Jewelry retail"
  },
  "entities": [
    {
      "name": "Product",
      "table": "products",
      "description": "Jewelry piece",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Enter name",
          "help_text": "Full name"
        },
        {
          "name": "category",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "ring",
            "necklace",
            "bracelet",
            "earring",
            "watch",
            "pendant",
            "brooch"
          ],
          "badge_colors": {
            "ring": "pink",
            "necklace": "purple",
            "bracelet": "blue",
            "earring": "amber",
            "watch": "slate",
            "pendant": "pink",
            "brooch": "green"
          }
        },
        {
          "name": "material",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "gold",
            "silver",
            "platinum",
            "rose_gold",
            "titanium",
            "stainless"
          ],
          "badge_colors": {
            "gold": "amber",
            "silver": "slate",
            "platinum": "purple",
            "rose_gold": "pink",
            "titanium": "blue",
            "stainless": "slate"
          }
        },
        {
          "name": "price",
          "db_type": "NUMERIC(12,2)",
          "ts_type": "number",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text",
          "validation": {
            "min": 0,
            "message": "Price must be a positive number"
          },
          "placeholder": "0.00",
          "help_text": "Price in USD"
        },
        {
          "name": "stock",
          "db_type": "INTEGER",
          "ts_type": "number",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
