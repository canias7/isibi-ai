  "dashboard": {
    "stat_cards": [
      {
        "label": "Total Books",
        "entity": "Book",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Total Patrons",
        "entity": "Patron",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
      {
        "label": "Total Fines Owed",
        "entity": "Patron",
        "method": "sum",
        "field": "fines_owed",
        "icon": "DollarSign",
        "color": "amber"
      },
      {
        "label": "Total Checkouts",
        "entity": "Checkout",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      }
