      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "type",
            "guide_name",
            "date",
            "time",
            "capacity"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Tours yet",
            "subtext": "Add your first tour",
            "action_label": "Add Tour"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "type",
            "guide_name",
            "date",
            "time",
            "capacity",
            "price",
            "status"
          ],
          "required_fields": [
            "name",
            "type"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "type",
            "guide_name",
            "date",
            "time",
            "capacity",
            "price",
            "status"
          ],
          "required_fields": [
            "name",
            "type"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/tours/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "type",
            "guide_name",
            "date"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "type",
                "guide_name",
                "date",
                "time",
                "capacity"
              ]
            }
          ]
        }
      }
    },
