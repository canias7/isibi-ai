{
  "_meta": {
    "app_name": "Vscode Extension ",
    "description": "Vscode Extension  management"
  },
  "entities": [
    {
      "name": "Plugin",
      "table": "plugins",
      "description": "Plugin",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "version",
          "db_type": "VARCHAR(20)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "downloads",
          "db_type": "INTEGER DEFAULT 0",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "rating",
          "db_type": "NUMERIC(3,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "development",
            "beta",
            "published",
            "deprecated"
          ],
          "badge_colors": {
            "development": "pink",
            "beta": "blue",
            "published": "green",
            "deprecated": "amber"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "version",
            "downloads",
            "rating",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Plugins yet",
            "subtext": "Add plugin",
            "action_label": "Add Plugin"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "version",
            "downloads",
            "rating",
            "status"
          ],
          "required_fields": [
            "name",
            "version"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "version",
            "downloads",
            "rating",
            "status"
          ],
          "required_fields": [
            "name",
            "version"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/plugins/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "version",
            "downloads",
            "rating"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "version",
                "downloads",
                "rating",
                "status"
              ]
            }
          ]
        }
      }
    },
