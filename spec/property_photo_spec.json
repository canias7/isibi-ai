          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "scheduled",
            "shooting",
            "editing",
            "delivered"
          ],
          "badge_colors": {
            "scheduled": "pink",
            "shooting": "blue",
            "editing": "green",
            "delivered": "amber"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "address",
            "agent",
            "date",
            "type",
            "price",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Shoots yet",
            "subtext": "Add shoot",
            "action_label": "Add Shoot"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "address",
            "agent",
            "date",
            "type",
            "price",
            "status"
          ],
          "required_fields": [
            "address",
            "agent"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "address",
            "agent",
            "date",
            "type",
            "price",
            "status"
          ],
          "required_fields": [
            "address",
            "agent"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/shoots/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "address"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "address",
            "agent",
            "date",
            "type"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "address",
                "agent",
                "date",
                "type",
                "price",
                "status"
              ]
            }
          ]
        }
      }
    },
