  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Install",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Completed Installs",
        "entity": "Install",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "done"
        },
        "icon": "CheckCircle",
        "color": "emerald"
      },
      {
        "label": "Total Price",
        "entity": "Install",
        "method": "sum",
        "field": "price",
        "icon": "DollarSign",
        "color": "amber"
