          "primary_fields": [
            "customer",
            "type",
            "brand",
            "price"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "customer",
                "type",
                "brand",
                "price",
                "status"
              ]
            }
          ]
        }
