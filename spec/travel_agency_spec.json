        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "destination",
            "duration_days",
            "price_per_person",
            "type",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Trips yet",
            "subtext": "Create your first trip",
            "action_label": "Add Trip"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "available",
                "sold_out",
                "coming_soon",
                "discontinued"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "name",
            "destination"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "destination",
            "duration_days",
            "price_per_person",
            "type",
            "status"
          ],
          "required_fields": [
            "name",
            "destination"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "destination",
            "duration_days",
            "price_per_person",
            "type",
            "status"
          ],
          "required_fields": [
            "name",
            "destination"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/trips/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "destination",
            "duration_days",
            "price_per_person"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "destination",
                "duration_days",
                "price_per_person",
                "type",
                "status"
              ]
            }
          ]
        }
      }
