{
  "_meta": {
    "app_name": "Invoice Generator",
    "description": "Invoicing tool"
  },
  "entities": [
    {
      "name": "Client",
      "table": "clients",
      "description": "Invoice client",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "name",
          "db_type": "VARCHAR(255) NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Enter name",
          "help_text": "Full name"
        },
        {
          "name": "email",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "validation": {
            "pattern": "^[^@]+@[^@]+\\.[^@]+$",
            "message": "Enter a valid email address"
          },
          "placeholder": "email@example.com",
          "help_text": "Primary email address"
        },
        {
          "name": "company",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "placeholder": "Company name",
          "help_text": "Organization or company name"
        },
        {
          "name": "address",
          "db_type": "TEXT",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": false,
          "show_in_form": true,
          "input_component": "textarea",
          "display_component": "text",
          "placeholder": "Street, City, State, ZIP",
          "help_text": "Full mailing address"
        },
        {
          "name": "phone",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "validation": {
            "pattern": "^\\+?[\\d\\s\\-\\(\\)]{7,20}$",
            "message": "Enter a valid phone number"
          },
          "placeholder": "+1 (555) 000-0000",
          "help_text": "Contact phone number"
        },
        {
          "name": "notes",
          "db_type": "TEXT",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "textarea",
          "display_component": "text",
          "placeholder": "Additional notes...",
          "help_text": "Internal notes (not visible to customers)"
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "name",
            "email",
            "company"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Clients yet",
            "subtext": "Create your first client",
            "action_label": "Add Client"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "name",
            "email",
            "company",
            "address",
            "phone"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "email",
            "company",
            "address"
          ],
          "required_fields": [
            "name",
            "email"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "name",
            "email",
            "company",
            "address"
          ],
          "required_fields": [
            "name",
            "email"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/clients/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "email",
            "company"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "email",
                "company"
              ]
            }
          ]
        }
      }
    },
    {
      "name": "Invoice",
      "table": "invoices",
      "description": "Invoice",
      "fields": [
        {
          "name": "id",
          "db_type": "UUID DEFAULT gen_random_uuid() PRIMARY KEY",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "org_id",
          "db_type": "UUID NOT NULL",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        },
        {
          "name": "client_id",
          "db_type": "UUID",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "relation_picker",
          "display_component": "relation_link",
          "foreign_key": {
            "table": "clients",
            "column": "id",
            "display_column": "name"
          }
        },
        {
          "name": "client_name",
          "db_type": "VARCHAR(255)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "invoice_number",
          "db_type": "VARCHAR(20)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text"
        },
        {
          "name": "amount",
          "db_type": "NUMERIC(12,2)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "text",
          "validation": {
            "min": 0,
            "message": "Amount must be a positive number"
          },
          "placeholder": "0.00",
          "help_text": "Amount in USD"
        },
        {
          "name": "due_date",
          "db_type": "DATE",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "date_input",
          "display_component": "date"
        },
        {
          "name": "status",
          "db_type": "VARCHAR(50)",
          "ts_type": "string",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "select",
          "display_component": "status_badge",
          "enum_values": [
            "draft",
            "sent",
            "paid",
            "overdue",
            "cancelled"
          ],
          "badge_colors": {
            "draft": "pink",
            "sent": "blue",
            "paid": "green",
            "overdue": "amber",
            "cancelled": "purple"
          }
        },
        {
          "name": "created_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "updated_at",
          "db_type": "TIMESTAMPTZ NOT NULL DEFAULT NOW()",
          "ts_type": "string",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "deleted_at",
          "db_type": "TIMESTAMPTZ",
          "ts_type": "string",
          "nullable": true,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "datetime"
        },
        {
          "name": "version",
          "db_type": "INTEGER NOT NULL DEFAULT 1",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": false,
          "show_in_form": false,
          "input_component": "none",
          "display_component": "text"
        }
      ],
      "ui_config": {
        "list_view": {
          "layout": "table",
          "columns": [
            "client_name",
            "invoice_number",
            "amount",
            "due_date",
            "status",
            "client_id"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Invoices yet",
            "subtext": "Create your first invoice",
            "action_label": "Add Invoice"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            },
            {
              "name": "Calendar",
              "layout": "calendar",
              "date_field": "due_date"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "draft",
                "sent",
                "paid",
                "overdue",
                "cancelled"
              ]
            }
          ],
          "default_sort": {
            "field": "created_at",
            "direction": "desc"
          },
          "searchable_fields": [
            "client_name",
            "invoice_number"
          ],
          "row_actions": [
            {
              "name": "Edit",
              "icon": "Pencil",
              "action": "edit"
            },
            {
              "name": "View",
              "icon": "Eye",
              "action": "view"
            },
            {
              "name": "Mark Paid",
              "icon": "CheckCircle",
              "action": "update_status",
              "value": "paid"
            },
            {
              "name": "Delete",
              "icon": "Trash2",
              "action": "delete",
              "confirm": true
            }
          ]
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client_name",
            "invoice_number",
            "amount",
            "due_date",
            "status",
            "client_id"
          ],
          "required_fields": [
            "client_name",
            "invoice_number"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "client_name",
            "invoice_number",
            "amount",
            "due_date",
            "status",
            "client_id"
          ],
          "required_fields": [
            "client_name",
            "invoice_number"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/invoices/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "client_name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "client_name",
            "invoice_number",
            "amount",
            "due_date"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "client_name",
                "invoice_number",
                "amount",
                "due_date",
                "status",
                "client_id"
              ]
            }
          ]
        }
      }
    },
