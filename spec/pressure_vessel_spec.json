          "type": "SlideOverForm",
          "field_order": [
            "facility",
            "vessel_id",
            "type",
            "result",
            "next_due",
            "status"
          ],
          "required_fields": [
            "facility",
            "vessel_id"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/inspections/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "facility"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "facility",
            "vessel_id",
            "type",
            "result"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "facility",
                "vessel_id",
                "type",
                "result",
                "next_due",
                "status"
              ]
            }
          ]
        }
      }
