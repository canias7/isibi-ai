            "type",
            "result",
            "next_due",
            "status"
          ],
          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Inspections yet",
            "subtext": "Add inspection",
            "action_label": "Add Inspection"
          },
          "views": [
            {
              "name": "Table",
              "layout": "table"
            },
            {
              "name": "Board",
              "layout": "kanban",
              "group_by": "status"
            },
            {
              "name": "Calendar",
              "layout": "calendar",
              "date_field": "next_due"
            }
          ],
          "quick_filters": [
            {
              "field": "status",
              "label": "Status",
              "options": [
                "scheduled",
                "inspected",
                "reported"
              ]
