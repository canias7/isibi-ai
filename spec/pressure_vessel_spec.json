  "dashboard": {
    "stat_cards": [
      {
        "label": "Total",
        "entity": "Inspection",
        "method": "count",
        "icon": "Box",
        "color": "pink"
      },
      {
        "label": "Active Inspections",
        "entity": "Inspection",
        "method": "count",
        "filter": {
          "field": "status",
          "value": "scheduled"
        },
        "icon": "Activity",
        "color": "green"
      },
      {
        "label": "Total Vessels",
        "entity": "Vessel",
        "method": "count",
        "icon": "Hash",
        "color": "blue"
      },
