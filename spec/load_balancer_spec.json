          "route": "/backends/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "name"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "name",
            "url",
            "weight",
            "health_check"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "name",
                "url",
                "weight",
                "health_check",
                "status"
              ]
            }
          ]
        }
      }
