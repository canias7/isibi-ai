          "nullable": false,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "text_input",
          "display_component": "text",
          "validation": {
            "rule": "unique",
            "message": "Must be unique"
          },
          "placeholder": "Enter code",
          "help_text": "Unique identifier code"
        },
        {
          "name": "budget",
          "db_type": "NUMERIC(15,2)",
          "ts_type": "number",
          "nullable": true,
          "editable": true,
          "show_in_table": true,
          "show_in_form": true,
          "input_component": "number_input",
          "display_component": "currency",
          "placeholder": "0.00",
          "help_text": "Budget amount",
          "validation": {
            "min": 0,
            "message": "Budget must be a positive number"
          }
        },
        {
          "name": "total_billed",
          "db_type": "NUMERIC(15,2) NOT NULL",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "number_input",
          "display_component": "currency",
          "computed": "SUM(time_entries.billable_amount)",
          "validation": {
            "min": 0
          },
          "placeholder": "0.00",
          "help_text": "Total amount"
        },
        {
          "name": "budget_remaining",
          "db_type": "NUMERIC(15,2) NOT NULL",
          "ts_type": "number",
          "nullable": false,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "number_input",
          "display_component": "currency",
          "computed": "budget - total_billed",
          "validation": {
            "min": 0
          },
          "placeholder": "0.00",
          "help_text": "Budget amount"
        },
        {
          "name": "budget_used_pct",
          "db_type": "NUMERIC(5,2)",
          "ts_type": "number",
          "nullable": true,
          "editable": false,
          "show_in_table": true,
          "show_in_form": false,
          "input_component": "number_input",
          "display_component": "percentage",
          "computed": "total_billed / budget * 100",
          "placeholder": "0.00",
          "help_text": "Budget amount"
        },
