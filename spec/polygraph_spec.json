            "purpose",
            "examiner",
            "date",
            "result",
            "status"
          ],
          "required_fields": [
            "subject",
            "purpose"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "subject",
            "purpose",
            "examiner",
            "date",
            "result",
            "status"
          ],
          "required_fields": [
            "subject",
            "purpose"
          ],
