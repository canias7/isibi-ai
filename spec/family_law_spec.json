            "opposing_party",
            "attorney",
            "status"
          ],
          "required_fields": [
            "client",
            "type"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/cases/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "client"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "client",
            "type",
            "opposing_party",
            "attorney"
