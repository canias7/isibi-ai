          "filters": [],
          "empty_state": {
            "icon": "Box",
            "heading": "No Orders yet",
            "subtext": "Add order",
            "action_label": "Add Order"
          }
        },
        "create_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer",
            "type",
            "binding",
            "quantity",
            "price",
            "status"
          ],
          "required_fields": [
            "customer",
            "type"
          ]
        },
        "edit_form": {
          "type": "SlideOverForm",
          "field_order": [
            "customer",
            "type",
            "binding",
            "quantity",
            "price",
            "status"
          ],
          "required_fields": [
            "customer",
            "type"
          ],
          "prefilled": true
        },
        "detail_view": {
          "route": "/orders/:id",
          "layout": "tabbed",
          "header": {
            "title_fields": [
              "customer"
            ],
            "badge_fields": []
          },
          "primary_fields": [
            "customer",
            "type",
            "binding",
            "quantity"
          ],
          "tabs": [
            {
              "name": "Overview",
              "fields": [
                "customer",
                "type",
                "binding",
                "quantity",
                "price",
                "status"
              ]
            }
          ]
        }
      }
    },
